---
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <nav class="navbar">
      <div class="nav-content">
        <div class="logo">
          <a href="/" class="logo-link">NR</a>
        </div>
        <div class="nav-links">
          <a href="/" class="nav-item">Home</a>
          <a href="/services" class="nav-item">Services</a>
          <a href="/case-studies" class="nav-item">Case Studies</a>
          <a href="/contact" class="nav-item">Contact</a>
        </div>
        <button class="mobile-menu" aria-label="Menu" aria-expanded="false">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </nav>
    <div class="wrapper">
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <div class="footer-content">
          <div class="footer-left">
            <span class="footer-logo">NR</span>
            <p>Senior Clinical Data Engineer</p>
          </div>
          <div class="footer-right">
            <a href="mailto:nruffinsecure@gmail.com" class="icon-link">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><rect width="20" height="16" x="2" y="4" rx="2"></rect><path
                  d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
              >
              nruffinsecure@gmail.com
            </a>
            <a
              href="https://www.linkedin.com/in/nicholas-ruffin-a9b767102"
              target="_blank"
              class="icon-link"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
                ></path><rect width="4" height="12" x="2" y="9"></rect><circle
                  cx="4"
                  cy="4"
                  r="2"></circle></svg
              >
              LinkedIn
            </a>
          </div>
        </div>
      </footer>
    </div>
    <style is:global>
      :root {
        --primary-color: #2997ff;
        --text-color: #f5f5f7;
        --background-color: #000;
        --hover-color: #0077ed;
        --nav-height: 44px;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        width: 100%;
        min-height: 100%;
        overflow-x: hidden;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Inter", sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        color: var(--text-color);
        background: var(--background-color);
        line-height: 1.47059;
        letter-spacing: -0.022em;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      .wrapper {
        width: 100%;
        position: relative;
        flex: 1;
        display: flex;
        flex-direction: column;
      }

      main {
        width: 100%;
        margin: 0;
        padding-top: var(--nav-height);
        flex: 1;
      }

      .navbar {
        background: rgba(0, 0, 0, 0.8);
        backdrop-filter: saturate(180%) blur(20px);
        position: fixed;
        width: 100%;
        top: 0;
        z-index: 9999;
        height: var(--nav-height);
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      }

      .nav-content {
        max-width: 980px;
        margin: 0 auto;
        padding: 0 22px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        height: 100%;
      }

      .logo-link {
        color: var(--text-color);
        font-size: 21px;
        font-weight: 600;
        text-decoration: none;
        opacity: 0.8;
        transition: opacity 0.3s;
      }

      .nav-links {
        display: flex;
        gap: 2.4em;
      }

      .nav-item {
        color: var(--text-color);
        text-decoration: none;
        font-size: 12px;
        opacity: 0.8;
        transition: opacity 0.3s;
      }

      .nav-item:hover,
      .logo-link:hover {
        opacity: 1;
      }

      .mobile-menu {
        display: none;
      }

      @media (max-width: 768px) {
        .nav-links {
          display: none;
        }

        .mobile-menu {
          display: block;
          background: none;
          border: none;
          cursor: pointer;
          padding: 0;
        }

        .mobile-menu span {
          display: block;
          width: 18px;
          height: 1.5px;
          background: var(--text-color);
          margin: 4px 0;
          transition: all 0.3s ease;
        }

        .mobile-menu.active span:nth-child(1) {
          transform: rotate(45deg) translate(5px, 5px);
        }

        .mobile-menu.active span:nth-child(2) {
          opacity: 0;
        }

        .mobile-menu.active span:nth-child(3) {
          transform: rotate(-45deg) translate(5px, -5px);
        }

        .nav-links.active {
          display: flex;
          position: fixed;
          top: var(--nav-height);
          left: 0;
          right: 0;
          background: rgba(0, 0, 0, 0.95);
          padding: 1rem;
          flex-direction: column;
          align-items: center;
        }
      }

      .site-footer {
        background: #000;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        padding: 60px 20px;
      }

      .footer-content {
        max-width: 980px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 30px;
      }

      .footer-logo {
        font-weight: 700;
        font-size: 20px;
        color: var(--text-color);
        margin-bottom: 8px;
        display: block;
      }

      .footer-left p {
        color: #86868b;
        font-size: 14px;
      }

      .footer-right {
        display: flex;
        gap: 24px;
        align-items: center;
        flex-wrap: wrap; /* Prevent overflow */
      }

      .footer-right a {
        color: #86868b;
        text-decoration: none;
        font-size: 14px;
        transition: color 0.2s;
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .footer-right a:hover {
        color: var(--primary-color);
      }

      @media (max-width: 600px) {
        .footer-content {
          flex-direction: column;
          align-items: center;
          text-align: center;
          gap: 40px;
        }
        .footer-right {
          flex-direction: column;
          gap: 16px;
        }
      }
    </style>

    <script>
      function initializeMenu() {
        const hamburger = document.querySelector(".mobile-menu");
        const navLinks = document.querySelector(".nav-links");

        if (!hamburger || !navLinks) return;

        function toggleMenu() {
          hamburger.classList.toggle("active");
          navLinks.classList.toggle("active");
          const isExpanded = navLinks.classList.contains("active");
          hamburger.setAttribute("aria-expanded", isExpanded.toString());
        }

        hamburger.addEventListener("click", toggleMenu);
      }

      initializeMenu();
      document.addEventListener("astro:after-swap", initializeMenu);
    </script>
  </body>
</html>
