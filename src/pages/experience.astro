---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Experience | Nick Ruffin">
  <div class="projects-container">
    <div class="projects-header">
      <span class="projects-tag">TRACK RECORD</span>
      <h1>Built it. Scaled it. Now I help you do the same.</h1>
      <p>
        The data monetization platform I built generates $7M+ in annual revenue,
        processes 4.8 billion de-identified records, and delivers to 50+ clients
        automatically. Here's how it came together.
      </p>
    </div>

    <!-- Data Monetization Platform -->
    <div class="one-card-wrapper">
      <div class="major-project-card">
        <h2>
          $7M+ Data Monetization Platform
        </h2>
        <p class="project-intro">
          Architected and built the entire data monetization infrastructure —
          from raw data transformation through expert determination and Datavant
          tokenization to automated client delivery on Snowflake and AWS.
        </p>
        <div class="stage-block">
          <div class="stage-title">
            <span>Stage 1</span>
            <hr />
          </div>
          <strong>Turning Raw Data into Revenue-Ready Assets</strong>
          <p>
            Designed and built data transformation pipelines that process
            billions of clinical claims records, turning raw upstream
            data into clean, compliant datasets ready for monetization.
          </p>
        </div>
        <div class="stage-block">
          <div class="stage-title">
            <span>Stage 2</span>
            <hr />
          </div>
          <strong>Privacy-First Data Linking at Scale</strong>
          <p>
            Implemented secure Datavant tokenization across 4.8 billion records,
            enabling cross-organization analytics while maintaining
            full HIPAA compliance through expert determination.
          </p>
        </div>
        <div class="stage-block">
          <div class="stage-title">
            <span>Stage 3</span>
            <hr />
          </div>
          <strong>Automating Delivery to Save 40+ Hours/Month</strong>
          <p>
            Built Airflow-orchestrated pipelines on AWS that replaced manual
            data delivery processes, enabling daily secure transfers to
            50+ clients with zero manual intervention.
          </p>
        </div>
        <div class="results-bar">
          <div class="result-stat">
            <span class="stat-number">$7M+</span>
            <span class="stat-label">Annual Revenue</span>
          </div>
          <div class="result-stat">
            <span class="stat-number">4.8B</span>
            <span class="stat-label">Records Processed</span>
          </div>
          <div class="result-stat">
            <span class="stat-number">50+</span>
            <span class="stat-label">Client Deliveries</span>
          </div>
          <div class="result-stat">
            <span class="stat-number">40+</span>
            <span class="stat-label">Hours Saved/Month</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Tech Stack -->
    <div class="stack-banner">
      <span class="stack-label">TECHNICAL EXPERTISE</span>
      <div class="stack-items">
        <span class="stack-item">Snowflake</span>
        <span class="stack-dot"></span>
        <span class="stack-item">AWS (S3, Lambda, MWAA)</span>
        <span class="stack-dot"></span>
        <span class="stack-item">Airflow</span>
        <span class="stack-dot"></span>
        <span class="stack-item">Python</span>
        <span class="stack-dot"></span>
        <span class="stack-item">Terraform</span>
        <span class="stack-dot"></span>
        <span class="stack-item">Datavant</span>
      </div>
    </div>

    <!-- Prior Leadership -->
    <div class="prior-section">
      <span class="prior-tag">PRIOR LEADERSHIP</span>
      <div class="prior-card">
        <h3>Director of Engineering — Nimble Solutions</h3>
        <p>
          Before building the data monetization platform, I led a 16-person
          engineering department across the US and India. I was hand-picked by
          the CIO, led technology due diligence for 4 acquisitions, traveled to
          Hyderabad to integrate an acquired dev team, and built enterprise
          systems that transformed business operations. That experience is why
          I build things that work at scale — not prototypes, not proofs of concept,
          but production systems that run reliably.
        </p>
      </div>
    </div>

    <!-- CTA -->
    <div class="case-cta">
      <p>This is the process I've built and can help you replicate.</p>
      <a href="/contact" class="cta-button">Start a Conversation</a>
    </div>
  </div>

  <style>
    .projects-container {
      min-height: 100vh;
      background:
        linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)),
        url("/images/case_studies_tech.png") no-repeat center center;
      background-size: cover;
      color: #f5f5f7;
      padding: 110px 24px 80px;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .projects-header {
      text-align: center;
      margin-bottom: 48px;
      max-width: 700px;
    }
    .projects-tag {
      font-size: 13px;
      letter-spacing: 0.13em;
      color: #2997ff;
      margin-bottom: 22px;
      display: block;
      font-weight: 600;
    }
    .projects-header h1 {
      font-size: 45px;
      font-weight: 600;
      margin-bottom: 14px;
    }
    .projects-header p {
      font-size: 19px;
      color: #b3b6c5;
      margin-bottom: 0;
      line-height: 1.5;
    }

    /* Card */
    .one-card-wrapper {
      display: flex;
      justify-content: center;
      width: 100%;
    }
    .major-project-card {
      background: rgba(255, 255, 255, 0.075);
      border-radius: 22px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.13);
      backdrop-filter: blur(13px) saturate(115%);
      max-width: 700px;
      padding: 54px 40px 44px 40px;
      color: #f5f5f7;
      display: flex;
      flex-direction: column;
      margin: 0 auto;
    }
    .major-project-card > h2 {
      font-size: 1.5rem;
      color: #2997ff;
      font-weight: 700;
      margin-bottom: 0.5rem;
      text-align: center;
    }
    .project-intro {
      font-size: 1rem;
      color: #a1a1a6;
      text-align: center;
      line-height: 1.6;
      margin-bottom: 2rem;
    }
    .stage-block {
      margin-bottom: 34px;
      display: flex;
      flex-direction: column;
    }
    .stage-title {
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .stage-title span {
      font-size: 1.1rem;
      font-weight: 700;
      color: #2997ff;
    }
    .stage-title hr {
      border: none;
      border-top: 2px solid #2997ff;
      flex: 1;
      margin: 0;
      opacity: 0.25;
    }
    .stage-block strong {
      display: block;
      margin-bottom: 7px;
      color: #f5f5f7;
      font-size: 1.05rem;
    }
    .stage-block p {
      margin-bottom: 9px;
      line-height: 1.64;
      color: #a1a1a6;
    }
    .phase-link {
      color: #2997ff;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.97rem;
    }
    .phase-link:hover {
      color: #147bcd;
      text-decoration: underline;
    }

    /* Results Bar */
    .results-bar {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-top: 1.5rem;
      padding: 24px;
      background: rgba(41, 151, 255, 0.07);
      border-radius: 14px;
      text-align: center;
    }
    .result-stat {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .stat-number {
      font-size: 1.8rem;
      font-weight: 700;
      color: #2997ff;
    }
    .stat-label {
      font-size: 0.85rem;
      color: #a1a1a6;
    }

    /* Results Bar - 4 columns */
    .results-bar {
      grid-template-columns: repeat(4, 1fr);
    }

    /* Prior Leadership */
    .prior-section {
      max-width: 700px;
      width: 100%;
      margin-top: 48px;
      text-align: center;
    }
    .prior-tag {
      font-size: 13px;
      letter-spacing: 0.13em;
      color: #2997ff;
      font-weight: 600;
      display: block;
      margin-bottom: 22px;
    }
    .prior-card {
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 18px;
      padding: 36px 32px;
      text-align: left;
    }
    .prior-card h3 {
      font-size: 1.2rem;
      font-weight: 700;
      color: #f5f5f7;
      margin-bottom: 12px;
    }
    .prior-card p {
      font-size: 1rem;
      color: #a1a1a6;
      line-height: 1.7;
    }

    /* Stack Banner */
    .stack-banner {
      max-width: 700px;
      width: 100%;
      text-align: center;
      margin-top: 48px;
      padding: 20px 24px;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 14px;
    }
    .stack-label {
      font-size: 11px;
      letter-spacing: 0.12em;
      color: #86868b;
      font-weight: 600;
      display: block;
      margin-bottom: 10px;
    }
    .stack-items {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
    }
    .stack-item {
      color: #f5f5f7;
      font-size: 15px;
      font-weight: 600;
    }
    .stack-dot {
      width: 4px;
      height: 4px;
      background: #2997ff;
      border-radius: 50%;
    }

    /* CTA */
    .case-cta {
      margin-top: 60px;
      text-align: center;
    }
    .case-cta p {
      font-size: 1.2rem;
      color: #a1a1a6;
      margin-bottom: 20px;
    }
    .cta-button {
      display: inline-block;
      padding: 14px 32px;
      background: #2997ff;
      color: white;
      border-radius: 30px;
      text-decoration: none;
      font-size: 17px;
      font-weight: 600;
      transition: opacity 0.3s;
    }
    .cta-button:hover {
      opacity: 0.8;
    }

    @media (max-width: 940px) {
      .major-project-card {
        max-width: 99vw;
        padding: 24px 6vw;
      }
      .projects-header h1 {
        font-size: 32px;
      }
      .results-bar {
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
      }
      .prior-card {
        padding: 24px 20px;
      }
    }
  </style>
</MainLayout>
