---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Experience | Nick Ruffin">
  <div class="projects-container">
    <canvas id="circuit-canvas"></canvas>
    <div class="projects-inner">
      <div class="projects-header">
        <span class="projects-tag reveal">TRACK RECORD</span>
        <h1 class="reveal reveal-delay-1">Leadership at the level the work demands.</h1>
        <p class="reveal reveal-delay-2">I lead the team behind a $9M ARR clinical data product I architected from the ground up. Before that, I ran three engineering teams across two continents.</p>
      </div>

      <div class="timeline reveal">
        <div class="timeline-item">
          <div class="timeline-marker"><span class="marker-dot"></span><span class="marker-line"></span></div>
          <div class="timeline-content">
            <div class="timeline-meta">
              <span class="role-time">RedSail Technologies</span>
              <span class="role-company">2024 &mdash; Present</span>
            </div>
            <h2>Manager, Data Product Engineering</h2>
            <p class="role-summary">Lead the team behind RedSail's $9M ARR clinical data monetization platform &mdash; a product I architected and built end-to-end before stepping into team leadership. Drive architecture, delivery, and day-to-day execution across enterprise pharma, life sciences, and RWE buyers.</p>
            <ul class="role-bullets">
              <li>Architected and built the original platform from scratch &mdash; de-identification, Datavant tokenization at 6B-record scale, Airflow-orchestrated delivery, Terraform-managed AWS and Snowflake. Drove from zero to first client revenue.</li>
              <li>Leading the V2 tokenization rebuild on MWAA V3 &mdash; parallel client chains, pre-hashed archive joins, IAM trust policy migration ahead of AWS V1 deprecation. <a href="/case-studies/v2-tokenization-rebuild">Case study</a>.</li>
              <li>Own client commitments, SLAs, and audit readiness across pharma, life sciences, and real-world evidence buyers.</li>
              <li>Coordinate across infra, analytics, and legal/compliance; manage Datavant and AWS relationships directly.</li>
              <li>Hands-on across Snowflake, Python, Terraform &mdash; bring my own keyboard when it accelerates the team.</li>
            </ul>
            <div class="results-bar">
              <div class="result-stat"><span class="stat-number">$9M+</span><span class="stat-label">ARR platform</span></div>
              <div class="result-stat"><span class="stat-number">6B</span><span class="stat-label">records</span></div>
              <div class="result-stat"><span class="stat-number">8+</span><span class="stat-label">enterprise clients</span></div>
              <div class="result-stat"><span class="stat-number">50+</span><span class="stat-label">daily workflows</span></div>
            </div>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-marker"><span class="marker-dot"></span></div>
          <div class="timeline-content">
            <div class="timeline-meta">
              <span class="role-time">2022 &mdash; 2024</span>
              <span class="role-company">Nimble Solutions</span>
            </div>
            <h2>Director of Full Stack Development</h2>
            <p class="role-summary">Hand-picked by the CIO. Led three separate engineering teams across the US and Hyderabad. Owned technology due diligence for four acquisitions and built systems that transformed operations.</p>
            <ul class="role-bullets">
              <li>Led tech due diligence for four acquisitions &mdash; reporting findings to the executive team.</li>
              <li>Traveled to Hyderabad to integrate an acquired engineering team into Nimble's stack and processes.</li>
              <li>Owned full-stack delivery across web, services, and data layers for an enterprise customer base.</li>
              <li>Built and managed remote and on-site engineering culture across two continents.</li>
            </ul>
            <div class="results-bar">
              <div class="result-stat"><span class="stat-number">3</span><span class="stat-label">teams led</span></div>
              <div class="result-stat"><span class="stat-number">4</span><span class="stat-label">acquisitions</span></div>
              <div class="result-stat"><span class="stat-number">2</span><span class="stat-label">continents</span></div>
            </div>
          </div>
        </div>
      </div>

      <div class="stack-banner reveal">
        <span class="stack-label">CURRENT STACK</span>
        <div class="stack-items">
          <span class="stack-item">Snowflake</span><span class="stack-dot"></span>
          <span class="stack-item">AWS (S3, Lambda, MWAA V3)</span><span class="stack-dot"></span>
          <span class="stack-item">Airflow</span><span class="stack-dot"></span>
          <span class="stack-item">Python</span><span class="stack-dot"></span>
          <span class="stack-item">Terraform</span><span class="stack-dot"></span>
          <span class="stack-item">Datavant</span>
        </div>
      </div>

      <div class="case-cta reveal">
        <p>Want to talk?</p>
        <a href="https://www.linkedin.com/in/nicholas-ruffin-a9b767102" target="_blank" rel="noopener" class="cta-button">Connect on LinkedIn</a>
      </div>
    </div>
  </div>

  <script>
    function initCircuit() {
      const canvas = document.getElementById('circuit-canvas') as HTMLCanvasElement;
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;
      let w = canvas.width = window.innerWidth;
      let h = canvas.height = canvas.parentElement!.scrollHeight;
      let animId: number;
      let time = 0;

      interface Node { x: number; y: number; pulsePhase: number; connections: number[]; }
      const nodes: Node[] = [];
      const gridSize = 80;
      const cols = Math.ceil(w / gridSize);
      const rows = Math.ceil(h / gridSize);

      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < cols; c++) {
          if (Math.random() > 0.3) continue;
          const node: Node = {
            x: c * gridSize + (Math.random() * 30 - 15),
            y: r * gridSize + (Math.random() * 30 - 15),
            pulsePhase: Math.random() * Math.PI * 2,
            connections: [],
          };
          nodes.push(node);
        }
      }
      // Connect nearby nodes
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const dx = nodes[i].x - nodes[j].x;
          const dy = nodes[i].y - nodes[j].y;
          if (Math.sqrt(dx*dx + dy*dy) < gridSize * 1.8 && nodes[i].connections.length < 3) {
            nodes[i].connections.push(j);
          }
        }
      }

      function draw() {
        ctx!.clearRect(0, 0, w, h);
        time += 0.01;

        // Draw connections with traveling pulse
        for (const node of nodes) {
          for (const ci of node.connections) {
            const target = nodes[ci];
            ctx!.beginPath();
            ctx!.moveTo(node.x, node.y);
            // Right-angle paths (circuit style)
            const midX = (node.x + target.x) / 2;
            ctx!.lineTo(midX, node.y);
            ctx!.lineTo(midX, target.y);
            ctx!.lineTo(target.x, target.y);
            ctx!.strokeStyle = 'rgba(168, 85, 247, 0.08)';
            ctx!.lineWidth = 1;
            ctx!.stroke();

            // Traveling pulse
            const pulsePos = (Math.sin(time * 2 + node.pulsePhase) + 1) / 2;
            const px = node.x + (target.x - node.x) * pulsePos;
            const py = node.y + (target.y - node.y) * pulsePos;
            const pulseGlow = ctx!.createRadialGradient(px, py, 0, px, py, 8);
            pulseGlow.addColorStop(0, 'rgba(168, 85, 247, 0.4)');
            pulseGlow.addColorStop(1, 'rgba(168, 85, 247, 0)');
            ctx!.fillStyle = pulseGlow;
            ctx!.beginPath();
            ctx!.arc(px, py, 8, 0, Math.PI * 2);
            ctx!.fill();
          }
        }

        // Draw nodes
        for (const node of nodes) {
          const pulse = Math.sin(time * 2 + node.pulsePhase) * 0.3 + 0.7;
          ctx!.beginPath();
          ctx!.arc(node.x, node.y, 2.5, 0, Math.PI * 2);
          ctx!.fillStyle = `rgba(168, 85, 247, ${0.4 * pulse})`;
          ctx!.fill();
        }

        animId = requestAnimationFrame(draw);
      }
      draw();
      window.addEventListener('resize', () => { w = canvas.width = window.innerWidth; h = canvas.height = canvas.parentElement!.scrollHeight; });
      document.addEventListener('astro:before-swap', () => cancelAnimationFrame(animId));
    }
    initCircuit();
    document.addEventListener('astro:after-swap', initCircuit);
  </script>

  <style>
    .projects-container {
      min-height: 100vh;
      background: var(--background-color);
      color: var(--text-color);
      padding: 110px 24px 80px;
      display: flex;
      flex-direction: column;
      align-items: center;
      position: relative;
    }
    #circuit-canvas { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; }
    .projects-inner { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; width: 100%; }
    .projects-header { text-align: center; margin-bottom: 48px; max-width: 700px; }
    .projects-tag { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.15em; color: var(--primary-color); margin-bottom: 22px; display: block; }
    .projects-header h1 { font-size: 42px; font-weight: 700; margin-bottom: 14px; }
    .projects-header p { font-size: 17px; color: var(--text-muted); line-height: 1.6; }

    .timeline {
      width: 100%;
      max-width: 820px;
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .timeline-item {
      display: grid;
      grid-template-columns: 32px 1fr;
      gap: 20px;
    }
    .timeline-marker {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding-top: 18px;
    }
    .marker-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: var(--primary-color);
      box-shadow: 0 0 0 4px rgba(168, 85, 247, 0.18);
      flex-shrink: 0;
      z-index: 1;
    }
    .marker-line {
      flex: 1;
      width: 2px;
      background: linear-gradient(180deg, rgba(168, 85, 247, 0.4) 0%, rgba(168, 85, 247, 0.05) 100%);
      margin-top: 4px;
      min-height: 60px;
    }
    .timeline-content {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: 14px;
      padding: 28px 32px;
      margin-bottom: 20px;
      transition: border-color 0.4s, box-shadow 0.4s, transform 0.4s;
      text-align: left;
    }
    .timeline-content:hover {
      border-color: rgba(168, 85, 247, 0.3);
      box-shadow: 0 8px 32px rgba(168, 85, 247, 0.1);
      transform: translateY(-2px);
    }
    .timeline-meta { display: flex; flex-direction: column; gap: 4px; margin-bottom: 14px; }
    .role-time {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.1em;
      color: var(--primary-color);
      text-transform: uppercase;
    }
    .role-company {
      font-size: 0.85rem;
      color: var(--text-muted);
      font-weight: 500;
    }
    .timeline-content h2 {
      font-size: 1.35rem;
      font-weight: 700;
      color: var(--text-color);
      margin-bottom: 0.7rem;
      letter-spacing: -0.01em;
    }
    .role-summary {
      font-size: 1rem;
      color: var(--text-muted);
      line-height: 1.65;
      margin-bottom: 1.2rem;
    }
    .role-bullets {
      list-style: none;
      padding: 0;
      margin: 0 0 1.2rem 0;
    }
    .role-bullets li {
      padding: 8px 0 8px 22px;
      position: relative;
      font-size: 0.93rem;
      color: var(--text-muted);
      line-height: 1.6;
    }
    .role-bullets li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 16px;
      width: 5px;
      height: 5px;
      background: var(--primary-color);
      border-radius: 50%;
    }
    .role-bullets a {
      color: var(--primary-color);
      text-decoration: none;
      font-weight: 500;
    }
    .role-bullets a:hover { opacity: 0.75; }

    .results-bar {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-top: 0.5rem;
      padding: 18px;
      background: var(--primary-subtle);
      border-radius: 10px;
      text-align: center;
      border: 1px solid var(--card-border);
    }
    .result-stat { display: flex; flex-direction: column; gap: 4px; }
    .stat-number { font-size: 1.3rem; font-weight: 700; color: var(--primary-color); font-family: 'JetBrains Mono', monospace; }
    .stat-label { font-size: 0.72rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; }

    .stack-banner { max-width: 820px; width: 100%; text-align: center; margin-top: 40px; padding: 20px 24px; background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 12px; }
    .stack-label { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.12em; color: var(--text-muted); display: block; margin-bottom: 10px; }
    .stack-items { display: flex; justify-content: center; align-items: center; gap: 16px; flex-wrap: wrap; }
    .stack-item { color: var(--text-color); font-size: 14px; font-weight: 500; }
    .stack-dot { width: 4px; height: 4px; background: var(--primary-color); border-radius: 50%; }

    .case-cta { margin-top: 60px; text-align: center; }
    .case-cta p { font-size: 1.1rem; color: var(--text-muted); margin-bottom: 20px; }
    .cta-button { display: inline-block; padding: 14px 32px; background: linear-gradient(135deg, #a855f7 0%, #7c3aed 100%); color: white; border-radius: 10px; text-decoration: none; font-size: 16px; font-weight: 600; box-shadow: 0 4px 24px var(--primary-glow); transition: all 0.3s; }
    .cta-button:hover { transform: translateY(-2px); box-shadow: 0 8px 40px rgba(168, 85, 247, 0.5); }

    @media (max-width: 768px) {
      .projects-header h1 { font-size: 30px; }
      .timeline-item { grid-template-columns: 24px 1fr; gap: 14px; }
      .timeline-content { padding: 22px 22px; }
      .results-bar { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</MainLayout>
