---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Experience | Nick Ruffin">
  <div class="projects-container">
    <canvas id="circuit-canvas"></canvas>
    <div class="projects-inner">
      <div class="projects-header">
        <span class="projects-tag reveal">TRACK RECORD</span>
        <h1 class="reveal reveal-delay-1">Built it. Scaled it. Running in production.</h1>
        <p class="reveal reveal-delay-2">The data monetization platform I built generates $9M+ in annual revenue, processes 6 billion de-identified records, and runs 50+ automated workflows daily.</p>
      </div>

      <div class="one-card-wrapper reveal">
        <div class="major-project-card">
          <h2>$9M+ Data Monetization Platform</h2>
          <p class="project-intro">Architected and built the entire data monetization infrastructure — from raw data transformation through expert determination and Datavant tokenization to automated client delivery on Snowflake and AWS.</p>
          <div class="stage-block">
            <div class="stage-title"><span>Stage 1</span><hr /></div>
            <strong>Turning Raw Data into Revenue-Ready Assets</strong>
            <p>Designed and built data transformation pipelines that process billions of clinical claims records, turning raw upstream data into clean, compliant datasets ready for monetization.</p>
          </div>
          <div class="stage-block">
            <div class="stage-title"><span>Stage 2</span><hr /></div>
            <strong>Privacy-First Data Linking at Scale</strong>
            <p>Implemented secure Datavant tokenization across 6 billion records, enabling cross-organization analytics while maintaining full HIPAA compliance through expert determination.</p>
          </div>
          <div class="stage-block">
            <div class="stage-title"><span>Stage 3</span><hr /></div>
            <strong>Automating Delivery to Save 40+ Hours/Month</strong>
            <p>Built Airflow-orchestrated pipelines on AWS that replaced manual data delivery processes, orchestrating 50+ daily workflows with zero manual intervention.</p>
          </div>
          <div class="results-bar">
            <div class="result-stat"><span class="stat-number">$9M+</span><span class="stat-label">Annual Revenue</span></div>
            <div class="result-stat"><span class="stat-number">6B</span><span class="stat-label">Records Processed</span></div>
            <div class="result-stat"><span class="stat-number">50+</span><span class="stat-label">Daily Workflows</span></div>
            <div class="result-stat"><span class="stat-number">40+</span><span class="stat-label">Hours Saved/Month</span></div>
          </div>
        </div>
      </div>

      <div class="stack-banner reveal">
        <span class="stack-label">TECHNICAL EXPERTISE</span>
        <div class="stack-items">
          <span class="stack-item">Snowflake</span><span class="stack-dot"></span>
          <span class="stack-item">AWS (S3, Lambda, MWAA)</span><span class="stack-dot"></span>
          <span class="stack-item">Airflow</span><span class="stack-dot"></span>
          <span class="stack-item">Python</span><span class="stack-dot"></span>
          <span class="stack-item">Terraform</span><span class="stack-dot"></span>
          <span class="stack-item">Datavant</span>
        </div>
      </div>

      <div class="prior-section reveal">
        <span class="prior-tag">PRIOR LEADERSHIP</span>
        <div class="prior-card">
          <h3>Director of Full Stack Development — Nimble Solutions</h3>
          <p>Before building the data monetization platform, I led a 16-person engineering department across the US and India. I was hand-picked by the CIO, led technology due diligence for 4 acquisitions, traveled to Hyderabad to integrate an acquired dev team, and built enterprise systems that transformed business operations.</p>
        </div>
      </div>

      <div class="case-cta reveal">
        <p>This is what I build.</p>
        <a href="/contact" class="cta-button">Get in Touch</a>
      </div>
    </div>
  </div>

  <script>
    function initCircuit() {
      const canvas = document.getElementById('circuit-canvas') as HTMLCanvasElement;
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;
      let w = canvas.width = window.innerWidth;
      let h = canvas.height = canvas.parentElement!.scrollHeight;
      let animId: number;
      let time = 0;

      interface Node { x: number; y: number; pulsePhase: number; connections: number[]; }
      const nodes: Node[] = [];
      const gridSize = 80;
      const cols = Math.ceil(w / gridSize);
      const rows = Math.ceil(h / gridSize);

      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < cols; c++) {
          if (Math.random() > 0.3) continue;
          const node: Node = {
            x: c * gridSize + (Math.random() * 30 - 15),
            y: r * gridSize + (Math.random() * 30 - 15),
            pulsePhase: Math.random() * Math.PI * 2,
            connections: [],
          };
          nodes.push(node);
        }
      }
      // Connect nearby nodes
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const dx = nodes[i].x - nodes[j].x;
          const dy = nodes[i].y - nodes[j].y;
          if (Math.sqrt(dx*dx + dy*dy) < gridSize * 1.8 && nodes[i].connections.length < 3) {
            nodes[i].connections.push(j);
          }
        }
      }

      function draw() {
        ctx!.clearRect(0, 0, w, h);
        time += 0.01;

        // Draw connections with traveling pulse
        for (const node of nodes) {
          for (const ci of node.connections) {
            const target = nodes[ci];
            ctx!.beginPath();
            ctx!.moveTo(node.x, node.y);
            // Right-angle paths (circuit style)
            const midX = (node.x + target.x) / 2;
            ctx!.lineTo(midX, node.y);
            ctx!.lineTo(midX, target.y);
            ctx!.lineTo(target.x, target.y);
            ctx!.strokeStyle = 'rgba(168, 85, 247, 0.08)';
            ctx!.lineWidth = 1;
            ctx!.stroke();

            // Traveling pulse
            const pulsePos = (Math.sin(time * 2 + node.pulsePhase) + 1) / 2;
            const px = node.x + (target.x - node.x) * pulsePos;
            const py = node.y + (target.y - node.y) * pulsePos;
            const pulseGlow = ctx!.createRadialGradient(px, py, 0, px, py, 8);
            pulseGlow.addColorStop(0, 'rgba(168, 85, 247, 0.4)');
            pulseGlow.addColorStop(1, 'rgba(168, 85, 247, 0)');
            ctx!.fillStyle = pulseGlow;
            ctx!.beginPath();
            ctx!.arc(px, py, 8, 0, Math.PI * 2);
            ctx!.fill();
          }
        }

        // Draw nodes
        for (const node of nodes) {
          const pulse = Math.sin(time * 2 + node.pulsePhase) * 0.3 + 0.7;
          ctx!.beginPath();
          ctx!.arc(node.x, node.y, 2.5, 0, Math.PI * 2);
          ctx!.fillStyle = `rgba(168, 85, 247, ${0.4 * pulse})`;
          ctx!.fill();
        }

        animId = requestAnimationFrame(draw);
      }
      draw();
      window.addEventListener('resize', () => { w = canvas.width = window.innerWidth; h = canvas.height = canvas.parentElement!.scrollHeight; });
      document.addEventListener('astro:before-swap', () => cancelAnimationFrame(animId));
    }
    initCircuit();
    document.addEventListener('astro:after-swap', initCircuit);
  </script>

  <style>
    .projects-container {
      min-height: 100vh;
      background: var(--background-color);
      color: var(--text-color);
      padding: 110px 24px 80px;
      display: flex;
      flex-direction: column;
      align-items: center;
      position: relative;
    }
    #circuit-canvas { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; }
    .projects-inner { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; width: 100%; }
    .projects-header { text-align: center; margin-bottom: 48px; max-width: 700px; }
    .projects-tag { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.15em; color: var(--primary-color); margin-bottom: 22px; display: block; }
    .projects-header h1 { font-size: 42px; font-weight: 700; margin-bottom: 14px; }
    .projects-header p { font-size: 17px; color: var(--text-muted); line-height: 1.6; }

    .one-card-wrapper { display: flex; justify-content: center; width: 100%; }
    .major-project-card {
      background: var(--card-bg);
      border-radius: 18px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
      backdrop-filter: blur(10px);
      max-width: 700px;
      padding: 48px 36px;
      display: flex;
      flex-direction: column;
      border: 1px solid var(--card-border);
      transition: border-color 0.4s, box-shadow 0.4s;
    }
    .major-project-card:hover { border-color: rgba(168, 85, 247, 0.3); box-shadow: 0 8px 40px rgba(168, 85, 247, 0.1); }
    .major-project-card > h2 { font-size: 1.5rem; color: var(--primary-color); font-weight: 700; margin-bottom: 0.5rem; text-align: center; }
    .project-intro { font-size: 0.95rem; color: var(--text-muted); text-align: center; line-height: 1.7; margin-bottom: 2rem; }
    .stage-block { margin-bottom: 28px; }
    .stage-title { margin-bottom: 8px; display: flex; align-items: center; gap: 14px; }
    .stage-title span { font-size: 1rem; font-weight: 700; color: var(--primary-color); font-family: 'JetBrains Mono', monospace; }
    .stage-title hr { border: none; border-top: 1px solid rgba(168, 85, 247, 0.2); flex: 1; margin: 0; }
    .stage-block strong { display: block; margin-bottom: 7px; color: var(--text-color); font-size: 1rem; }
    .stage-block p { line-height: 1.7; color: var(--text-muted); font-size: 0.95rem; }
    .results-bar { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 1.5rem; padding: 24px; background: var(--primary-subtle); border-radius: 12px; text-align: center; border: 1px solid var(--card-border); }
    .result-stat { display: flex; flex-direction: column; gap: 4px; }
    .stat-number { font-size: 1.6rem; font-weight: 700; color: var(--primary-color); }
    .stat-label { font-size: 0.8rem; color: var(--text-muted); }

    .stack-banner { max-width: 700px; width: 100%; text-align: center; margin-top: 48px; padding: 20px 24px; background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 12px; }
    .stack-label { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.12em; color: var(--text-muted); display: block; margin-bottom: 10px; }
    .stack-items { display: flex; justify-content: center; align-items: center; gap: 16px; flex-wrap: wrap; }
    .stack-item { color: var(--text-color); font-size: 14px; font-weight: 500; }
    .stack-dot { width: 4px; height: 4px; background: var(--primary-color); border-radius: 50%; }

    .prior-section { max-width: 700px; width: 100%; margin-top: 48px; text-align: center; }
    .prior-tag { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.15em; color: var(--primary-color); display: block; margin-bottom: 22px; }
    .prior-card { background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 16px; padding: 32px; text-align: left; transition: border-color 0.4s, box-shadow 0.4s; }
    .prior-card:hover { border-color: rgba(168, 85, 247, 0.25); box-shadow: 0 4px 20px rgba(168, 85, 247, 0.08); }
    .prior-card h3 { font-size: 1.1rem; font-weight: 700; color: var(--text-color); margin-bottom: 12px; }
    .prior-card p { font-size: 0.95rem; color: var(--text-muted); line-height: 1.7; }

    .case-cta { margin-top: 60px; text-align: center; }
    .case-cta p { font-size: 1.1rem; color: var(--text-muted); margin-bottom: 20px; }
    .cta-button { display: inline-block; padding: 14px 32px; background: linear-gradient(135deg, #a855f7 0%, #7c3aed 100%); color: white; border-radius: 10px; text-decoration: none; font-size: 16px; font-weight: 600; box-shadow: 0 4px 24px var(--primary-glow); transition: all 0.3s; }
    .cta-button:hover { transform: translateY(-2px); box-shadow: 0 8px 40px rgba(168, 85, 247, 0.5); }

    @media (max-width: 768px) {
      .projects-header h1 { font-size: 30px; }
      .major-project-card { padding: 24px 20px; }
      .results-bar { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</MainLayout>
