---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Contact | Senior Clinical Data Engineer">
  <div class="contact-container">
    <div class="contact-content">
      <div class="contact-header">
        <span class="tag">CONNECT</span>
        <h1>Get in Touch</h1>
        <p>
          Building something complex? Looking for a Senior Data Engineer? I'm
          always open to discussing architecture, opportunities, or
          collaboration.
        </p>
      </div>

      <div class="form-card">
        <form
          action="https://formspree.io/f/mjkvovpw"
          method="POST"
          class="contact-form"
        >
          <div class="form-group">
            <label for="name">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              placeholder="Your Name"
              required
            />
          </div>

          <div class="form-group">
            <label for="email">Work Email</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="name@company.com"
              required
            />
          </div>

          <div class="form-group">
            <label for="company">Company / Organization</label>
            <input
              type="text"
              id="company"
              name="company"
              placeholder="Company Name (Optional)"
            />
          </div>

          <div class="form-group">
            <label for="message">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              placeholder="Hi Nicholas, I'd like to discuss..."
              required></textarea>
          </div>

          <button type="submit" class="submit-btn">
            Send Message <span class="arrow">→</span>
          </button>
        </form>
      </div>
    </div>
  </div>

  <style>
    .contact-container {
      min-height: 100vh;
      background:
        linear-gradient(rgba(0, 0, 0, 0.8), rgba(0, 0, 0, 0.8)),
        url("/images/contact_tech.png") no-repeat center center;
      background-size: cover;
      color: #f5f5f7;
      padding-top: 120px;
      padding-bottom: 80px;
      display: flex;
      justify-content: center;
    }

    .contact-content {
      width: 100%;
      max-width: 600px;
      padding: 0 20px;
    }

    .contact-header {
      text-align: center;
      margin-bottom: 40px;
    }

    .tag {
      color: #2997ff;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.1em;
      display: block;
      margin-bottom: 16px;
    }

    h1 {
      font-size: 40px;
      font-weight: 700;
      line-height: 1.1;
      margin-bottom: 16px;
      letter-spacing: -0.02em;
    }

    p {
      color: #a1a1a6;
      font-size: 19px;
      line-height: 1.5;
    }

    .form-card {
      background: rgba(28, 28, 30, 0.6);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 24px;
      padding: 40px;
    }

    .form-group {
      margin-bottom: 24px;
    }

    label {
      display: block;
      font-size: 14px;
      font-weight: 500;
      color: #f5f5f7;
      margin-bottom: 8px;
    }

    input,
    textarea {
      width: 100%;
      background: rgba(0, 0, 0, 0.3);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 12px;
      padding: 12px 16px;
      color: #fff;
      font-size: 16px;
      font-family: inherit;
      transition: border-color 0.2s;
    }

    input:focus,
    textarea:focus {
      outline: none;
      border-color: #2997ff;
    }

    .submit-btn {
      width: 100%;
      background: #2997ff;
      color: white;
      border: none;
      border-radius: 12px;
      padding: 16px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 8px;
      transition: background-color 0.2s;
    }

    .submit-btn:hover {
      background: #0077ed;
    }

    @media (max-width: 768px) {
      .form-card {
        padding: 24px;
      }
      h1 {
        font-size: 32px;
      }
    }
  </style>
</MainLayout>
