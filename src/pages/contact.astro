---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Contact | Nicholas Ruffin">
  <div class="contact-container">
    <div class="contact-card">
      <div class="contact-header">
        <span class="tag">CONNECT</span>
        <h1>Get in Touch</h1>
        <p>
          I am currently open to discussing new opportunities, architecture
          challenges, and collaborations. The best way to reach me is directly
          via LinkedIn or Email.
        </p>
      </div>

      <div class="action-buttons">
        <a
          href="https://www.linkedin.com/in/nicholas-ruffin-a9b767102"
          target="_blank"
          class="primary-btn"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
            ></path><rect width="4" height="12" x="2" y="9"></rect><circle
              cx="4"
              cy="4"
              r="2"></circle></svg
          >
          Connect on LinkedIn
        </a>

        <a href="mailto:nruffinsecure@gmail.com" class="secondary-btn">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><rect width="20" height="16" x="2" y="4" rx="2"></rect><path
              d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
          >
          nruffinsecure@gmail.com
        </a>
      </div>

      <div class="resume-section">
        <span class="resume-label">Need a PDF?</span>
        <a href="/documents/resume.pdf" class="resume-link" download>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
            ></path><polyline points="7 10 12 15 17 10"></polyline><line
              x1="12"
              x2="12"
              y1="15"
              y2="3"></line></svg
          >
          Download Resume
        </a>
      </div>
    </div>
  </div>

  <style>
    .contact-container {
      min-height: 85vh;
      background:
        linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.8)),
        url("/images/contact_tech.png") no-repeat center center;
      background-size: cover;
      color: #f5f5f7;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 20px;
    }

    .contact-card {
      background: rgba(28, 28, 30, 0.7);
      backdrop-filter: blur(30px);
      -webkit-backdrop-filter: blur(30px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 24px;
      padding: 60px 40px;
      max-width: 540px;
      width: 100%;
      text-align: center;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    }

    .contact-header {
      margin-bottom: 40px;
    }

    .tag {
      color: #2997ff;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.15em;
      display: block;
      margin-bottom: 16px;
    }

    h1 {
      font-size: 42px;
      font-weight: 700;
      margin-bottom: 16px;
      color: #fff;
    }

    p {
      color: #a1a1a6;
      font-size: 18px;
      line-height: 1.6;
    }

    .action-buttons {
      display: flex;
      flex-direction: column;
      gap: 16px;
      margin-bottom: 40px;
    }

    .primary-btn,
    .secondary-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      padding: 18px;
      border-radius: 12px;
      font-size: 18px;
      font-weight: 600;
      text-decoration: none;
      transition:
        transform 0.2s,
        background-color 0.2s;
    }

    .primary-btn {
      background: #0a66c2; /* LinkedIn Blue */
      color: white;
      border: none;
    }

    .primary-btn:hover {
      background: #004182;
      transform: translateY(-2px);
    }

    .secondary-btn {
      background: rgba(255, 255, 255, 0.1);
      color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .secondary-btn:hover {
      background: rgba(255, 255, 255, 0.2);
      transform: translateY(-2px);
    }

    .resume-section {
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      padding-top: 24px;
      margin-top: 24px;
    }

    .resume-label {
      display: block;
      font-size: 14px;
      color: #86868b;
      margin-bottom: 12px;
    }

    .resume-link {
      color: #f5f5f7;
      font-size: 16px;
      font-weight: 500;
      text-decoration: none;
      transition: color 0.2s;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 20px;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 50px;
    }

    .resume-link:hover {
      color: #2997ff;
      background: rgba(255, 255, 255, 0.1);
    }

    @media (max-width: 600px) {
      .contact-card {
        padding: 40px 24px;
      }
      h1 {
        font-size: 32px;
      }
    }
  </style>
</MainLayout>
