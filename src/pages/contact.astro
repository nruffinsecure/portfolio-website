---
import MainLayout from "../layouts/MainLayout.astro";
const hasError = Astro.url.searchParams.get("error") === "true";
---

<MainLayout title="Contact | Clearflow Data">
  <div class="contact-container">
    <div class="contact-card">
      <div class="contact-header">
        <span class="tag">LET'S TALK</span>
        <h1>Start a Conversation</h1>
        <p>
          Tell me about your data challenges. I'll follow up within 24 hours with an honest take on how I can help.
        </p>
      </div>

      <!-- Calendly Embed -->
      <div class="calendly-section">
        <a href="https://calendly.com/nickruffin" target="_blank" class="calendly-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect><line x1="16" x2="16" y1="2" y2="6"></line><line x1="8" x2="8" y1="2" y2="6"></line><line x1="3" x2="21" y1="10" y2="10"></line></svg>
          Schedule a Discovery Call
        </a>
      </div>

      <div class="or-divider">
        <span>or send a message</span>
      </div>

      {hasError && (
        <div class="error-banner">
          Something went wrong. Please try again or email us directly at nruffinsecure@gmail.com.
        </div>
      )}

      <!-- Intake Form -->
      <form class="intake-form" action="/api/submit-quote" method="POST">
        <div class="form-group">
          <label for="name">Your Name</label>
          <input type="text" id="name" name="name" required placeholder="John Smith" />
        </div>
        <div class="form-group">
          <label for="business">Business Name</label>
          <input type="text" id="business" name="business" required placeholder="Acme Corp" />
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required placeholder="john@acmecorp.com" />
        </div>
        <div class="form-group">
          <label for="tools">What's your current data stack?</label>
          <input type="text" id="tools" name="tools" placeholder="Snowflake, AWS, Redshift, manual processes, etc." />
        </div>
        <div class="form-group">
          <label for="pain_point">What are you trying to solve?</label>
          <textarea id="pain_point" name="pain_point" rows="4" required placeholder="e.g., We need to de-identify and deliver claims data to external partners but don't have the pipeline infrastructure..."></textarea>
        </div>
        <button type="submit" class="submit-btn">Send Message</button>
      </form>

      <div class="divider"></div>

      <!-- Alternative Contact -->
      <div class="alt-contact">
        <p class="alt-label">Prefer to reach out directly?</p>
        <div class="action-buttons">
          <a
            href="https://www.linkedin.com/in/nicholas-ruffin-a9b767102"
            target="_blank"
            class="secondary-btn"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"></circle></svg>
            LinkedIn
          </a>
          <a href="mailto:nruffinsecure@gmail.com" class="secondary-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
            nruffinsecure@gmail.com
          </a>
        </div>
      </div>
    </div>
  </div>

  <style>
    .contact-container {
      min-height: 85vh;
      background:
        linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.8)),
        url("/images/contact_tech.png") no-repeat center center;
      background-size: cover;
      color: #f5f5f7;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 80px 20px;
    }
    .contact-card {
      background: rgba(28, 28, 30, 0.7);
      backdrop-filter: blur(30px);
      -webkit-backdrop-filter: blur(30px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 24px;
      padding: 60px 40px;
      max-width: 580px;
      width: 100%;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    }
    .contact-header {
      margin-bottom: 32px;
      text-align: center;
    }
    .tag {
      color: #2997ff;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.15em;
      display: block;
      margin-bottom: 16px;
    }
    .contact-header h1 {
      font-size: 36px;
      font-weight: 700;
      margin-bottom: 16px;
      color: #fff;
    }
    .contact-header p {
      color: #a1a1a6;
      font-size: 16px;
      line-height: 1.6;
    }

    /* Calendly Section */
    .calendly-section {
      text-align: center;
      margin-bottom: 8px;
    }
    .calendly-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: 100%;
      padding: 18px;
      background: #2997ff;
      color: white;
      border-radius: 12px;
      font-size: 18px;
      font-weight: 600;
      text-decoration: none;
      transition: opacity 0.3s;
    }
    .calendly-btn:hover {
      opacity: 0.8;
    }
    .or-divider {
      text-align: center;
      margin: 24px 0;
      position: relative;
    }
    .or-divider::before {
      content: "";
      position: absolute;
      top: 50%;
      left: 0;
      right: 0;
      height: 1px;
      background: rgba(255, 255, 255, 0.1);
    }
    .or-divider span {
      position: relative;
      background: rgba(28, 28, 30, 0.9);
      padding: 0 16px;
      color: #86868b;
      font-size: 14px;
    }

    /* Error Banner */
    .error-banner {
      background: rgba(255, 59, 48, 0.15);
      border: 1px solid rgba(255, 59, 48, 0.3);
      border-radius: 10px;
      padding: 14px 16px;
      margin-bottom: 24px;
      color: #ff6b6b;
      font-size: 15px;
      text-align: center;
    }

    /* Form Styles */
    .intake-form {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }
    .form-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .form-group label {
      font-size: 14px;
      color: #a1a1a6;
      font-weight: 500;
    }
    .form-group input,
    .form-group textarea {
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 10px;
      padding: 14px 16px;
      color: #f5f5f7;
      font-size: 16px;
      font-family: inherit;
      transition: border-color 0.2s;
      outline: none;
    }
    .form-group input::placeholder,
    .form-group textarea::placeholder {
      color: rgba(255, 255, 255, 0.25);
    }
    .form-group input:focus,
    .form-group textarea:focus {
      border-color: #2997ff;
    }
    .form-group textarea {
      resize: vertical;
    }
    .submit-btn {
      padding: 16px;
      background: #2997ff;
      color: white;
      border: none;
      border-radius: 12px;
      font-size: 17px;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.3s;
      font-family: inherit;
    }
    .submit-btn:hover {
      opacity: 0.8;
    }

    .divider {
      height: 1px;
      background: rgba(255, 255, 255, 0.1);
      margin: 32px 0;
    }

    /* Alt Contact */
    .alt-contact {
      text-align: center;
    }
    .alt-label {
      font-size: 14px;
      color: #86868b;
      margin-bottom: 16px;
    }
    .action-buttons {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .secondary-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 14px;
      border-radius: 10px;
      font-size: 16px;
      font-weight: 500;
      text-decoration: none;
      background: rgba(255, 255, 255, 0.06);
      color: #d2d2d7;
      border: 1px solid rgba(255, 255, 255, 0.08);
      transition: background 0.2s;
    }
    .secondary-btn:hover {
      background: rgba(255, 255, 255, 0.12);
    }

    @media (max-width: 600px) {
      .contact-card {
        padding: 40px 20px;
      }
      .contact-header h1 {
        font-size: 28px;
      }
    }
  </style>
</MainLayout>
