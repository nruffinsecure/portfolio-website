---
import MainLayout from "../layouts/MainLayout.astro";
import Experience from "../components/Experience.astro";
---

<MainLayout title="Services | Data Engineering Consultant">
  <div class="services-container">
    <div class="services-header">
      <span class="service-tag">SERVICES</span>
      <h1>Senior Clinical Data Engineer</h1>
      <p>
        Architecting secure, compliant, and scalable data ecosystems for Pharma
        & Healthcare.
      </p>
    </div>

    <!-- Intro / Bio Section -->
    <div class="services-grid">
      <div class="service-card featured" style="max-width:800px;">
        <div class="service-content">
          <h2>Nicholas Ruffin, Senior Clinical Data Engineer</h2>
          <p class="bio">
            I specialize in building high-performance data infrastructure for
            regulated industries. My recent work includes architecting a data
            monetization platform that drives <strong
              >$7M+ in annual revenue</strong
            > and engineering de-identification pipelines for <strong
              >4.8 billion clinical records</strong
            >.
          </p>
          <p class="bio">
            From raw data ingestion to secure analytics delivery, I leverage the
            modern data stack—<strong
              >Snowflake, Airflow, AWS, and Python</strong
            >—to turn massive datasets into actionable business value, all while
            ensuring strict HIPAA/GDPR compliance.
          </p>
          <div class="divider"></div>
          <ul class="features">
            <li>
              <strong>Monetization & Strategy</strong>: Tokenization (Datavant),
              Privacy Engineering, Revenue-Generating Pipelines
            </li>
            <li>
              <strong>Cloud Architecture</strong>: Snowflake Optimization, AWS
              (S3, Lambda, EventBridge, MWAA)
            </li>
            <li>
              <strong>Orchestration</strong>: Advanced Airflow DAGs, Python
              Automation, CI/CD (GitHub Actions)
            </li>
            <li>
              <strong>Compliance</strong>: HIPAA-safe handling of PII/PHI,
              De-identification frameworks
            </li>
          </ul>
          <div class="divider"></div>
          <p style="color:#b1c4e0; font-size:16px; margin:14px 0 4px;">
            Interested in my background or architecture? <br />
            <span style="color:#2997ff;">Let’s connect.</span>
          </p>
          <a href="/contact" class="cta-button" style="margin-top:18px;">
            Reach Out <span class="arrow">></span>
          </a>
        </div>
      </div>
    </div>

    <!-- Experience Section Insert -->
    <div style="width: 100%; margin-top: 80px;">
      <Experience />
    </div>
  </div>
  <style>
    .services-container {
      min-height: 100vh;
      background:
        linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)),
        url("/images/services_tech.png") no-repeat center center;
      background-size: cover;
      color: #f5f5f7;
      padding: 120px 20px;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .services-header {
      text-align: center;
      margin-bottom: 60px;
      max-width: 600px;
    }
    .service-tag {
      font-size: 12px;
      letter-spacing: 0.1em;
      color: #2997ff;
      margin-bottom: 16px;
      display: block;
    }
    h1 {
      font-size: 48px;
      font-weight: 600;
      margin-bottom: 16px;
      letter-spacing: -0.003em;
    }
    .services-header p {
      font-size: 21px;
      color: #86868b;
    }
    .services-grid {
      display: flex;
      justify-content: center;
      align-items: center;
      width: 100%;
      min-height: 60vh;
      max-width: 1200px;
    }
    .service-card {
      background: rgba(255, 255, 255, 0.05);
      border-radius: 18px;
      backdrop-filter: blur(20px);
      padding: 32px;
      transition: transform 0.3s ease;
      box-shadow: 0 2px 14px 0 rgba(44, 62, 80, 0.14);
      margin: 0 auto;
    }
    .service-card.featured {
      background: rgba(255, 255, 255, 0.1);
      transform: scale(1.01);
    }
    .service-content {
      display: flex;
      flex-direction: column;
      height: 100%;
    }
    h2 {
      font-size: 28px;
      font-weight: 600;
      margin-bottom: 8px;
    }
    .bio {
      font-size: 17px;
      color: #b1c4e0;
      margin-bottom: 14px;
      line-height: 1.7;
    }
    .divider {
      height: 1px;
      background: rgba(255, 255, 255, 0.1);
      margin: 22px 0;
    }
    .features {
      list-style: none;
      padding: 0;
      margin: 0 0 15px 0;
      flex-grow: 1;
    }
    .features li {
      padding: 10px 0;
      color: #86868b;
      font-size: 17px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }
    .features li:last-child {
      border-bottom: none;
    }
    .cta-button {
      color: #2997ff;
      text-decoration: none;
      font-size: 17px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      transition: opacity 0.3s;
      font-weight: 500;
    }
    .cta-button:hover {
      opacity: 0.7;
    }
    .arrow {
      font-size: 14px;
    }
    @media (max-width: 768px) {
      .services-container {
        padding: 80px 20px;
      }
      h1 {
        font-size: 32px;
      }
      .services-header p {
        font-size: 17px;
      }
      .services-grid {
        flex-direction: column;
        align-items: center;
      }
    }
  </style>
</MainLayout>
