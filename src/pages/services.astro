---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Services | Nick Ruffin">
  <div class="services-container">
    <div class="services-header">
      <span class="service-tag">SERVICES</span>
      <h1>Healthcare data engineering — done right</h1>
      <p>
        I specialize in de-identification pipelines and secure data delivery on Snowflake and AWS. From architecture to production — I build the infrastructure that turns sensitive data into compliant, monetizable assets.
      </p>
    </div>

    <!-- Tech Stack Banner -->
    <div class="stack-banner">
      <span class="stack-label">BUILT ON</span>
      <div class="stack-items">
        <span class="stack-item">Snowflake</span>
        <span class="stack-dot"></span>
        <span class="stack-item">AWS (S3, Lambda, MWAA)</span>
        <span class="stack-dot"></span>
        <span class="stack-item">Airflow</span>
        <span class="stack-dot"></span>
        <span class="stack-item">Python</span>
      </div>
    </div>

    <div class="tiers-grid">
      <!-- Tier 1: Assessment & Strategy -->
      <div class="tier-card">
        <div class="tier-badge">Engagement Start</div>
        <h2>Assessment & Strategy</h2>
        <div class="tier-tagline">2-3 week engagement</div>
        <p class="tier-problem">
          Not sure what your data infrastructure needs? I'll evaluate what you have and architect what you need.
        </p>
        <div class="divider"></div>
        <h3>What's Included</h3>
        <ul class="tier-features">
          <li>Full audit of current data infrastructure and pipelines</li>
          <li>Gap analysis: what's missing, what's broken, what's costing you</li>
          <li>Technical architecture blueprint for the build</li>
          <li>Compliance and de-identification strategy review</li>
          <li>Detailed scope and estimate for implementation</li>
        </ul>
        <div class="divider"></div>
        <p class="tier-ideal"><strong>Ideal for:</strong> Organizations that need a clear technical roadmap before committing to a build.</p>
        <a href="/contact" class="cta-button">Start Here</a>
      </div>

      <!-- Tier 2: Pipeline Build -->
      <div class="tier-card featured">
        <div class="tier-badge popular">Core Engagement</div>
        <h2>Pipeline Build</h2>
        <div class="tier-tagline">Scoped to your pipeline</div>
        <p class="tier-problem">
          You need a production pipeline that ingests, de-identifies, and delivers data to your clients — automatically.
        </p>
        <div class="divider"></div>
        <h3>What's Included</h3>
        <ul class="tier-features">
          <li>End-to-end pipeline: ingestion, transformation, de-identification</li>
          <li>Automated delivery to external clients (S3, Snowflake shares, SFTP)</li>
          <li>Orchestration with Airflow (MWAA)</li>
          <li>Built on your Snowflake + AWS infrastructure</li>
          <li>Full documentation, testing, and production deployment</li>
        </ul>
        <div class="divider"></div>
        <p class="tier-ideal"><strong>Ideal for:</strong> Healthcare and pharma companies monetizing data or delivering to external partners.</p>
        <a href="/contact" class="cta-button">Let's Talk</a>
      </div>

      <!-- Tier 3: Retained Engineering -->
      <div class="tier-card">
        <div class="tier-badge">Ongoing</div>
        <h2>Retained Engineering</h2>
        <div class="tier-tagline">Monthly retainer</div>
        <p class="tier-problem">
          Your pipelines are running. Now you need someone to manage them, onboard new deliveries, and keep everything optimized.
        </p>
        <div class="divider"></div>
        <h3>What's Included</h3>
        <ul class="tier-features">
          <li>Pipeline monitoring, maintenance, and incident response</li>
          <li>New client delivery onboarding and configuration</li>
          <li>Performance optimization and Snowflake cost management</li>
          <li>Infrastructure scaling as data volume grows</li>
          <li>Regular strategy calls and progress reporting</li>
        </ul>
        <div class="divider"></div>
        <p class="tier-ideal"><strong>Ideal for:</strong> Organizations that need dedicated data engineering support without a full-time hire.</p>
        <a href="/contact" class="cta-button">Let's Talk</a>
      </div>
    </div>

    <!-- Process Section -->
    <div class="process-section">
      <span class="service-tag">HOW I WORK</span>
      <h2>Straightforward engagement process</h2>
      <div class="process-steps">
        <div class="step">
          <span class="step-number">01</span>
          <h4>Discovery Call</h4>
          <p>We discuss your data challenges, current infrastructure, and what you're trying to achieve.</p>
        </div>
        <div class="step">
          <span class="step-number">02</span>
          <h4>Scope & Proposal</h4>
          <p>I deliver a clear technical scope, fixed price, and timeline. No ambiguity.</p>
        </div>
        <div class="step">
          <span class="step-number">03</span>
          <h4>Build & Deploy</h4>
          <p>I build on your infrastructure, test thoroughly, and deploy to production with regular check-ins.</p>
        </div>
        <div class="step">
          <span class="step-number">04</span>
          <h4>Handoff or Retain</h4>
          <p>Full documentation and knowledge transfer — or transition to a retained engineering relationship.</p>
        </div>
      </div>
    </div>
  </div>

  <style>
    .services-container {
      min-height: 100vh;
      background:
        linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)),
        url("/images/services_tech.png") no-repeat center center;
      background-size: cover;
      color: #f5f5f7;
      padding: 120px 20px 80px;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .services-header {
      text-align: center;
      margin-bottom: 60px;
      max-width: 600px;
    }
    .service-tag {
      font-size: 12px;
      letter-spacing: 0.1em;
      color: #2997ff;
      margin-bottom: 16px;
      display: block;
      font-weight: 600;
    }
    .services-header h1 {
      font-size: 48px;
      font-weight: 600;
      margin-bottom: 16px;
      letter-spacing: -0.003em;
    }
    .services-header p {
      font-size: 21px;
      color: #86868b;
    }

    /* Stack Banner */
    .stack-banner {
      max-width: 700px;
      width: 100%;
      text-align: center;
      margin-bottom: 48px;
      padding: 20px 24px;
      background: rgba(41, 151, 255, 0.06);
      border: 1px solid rgba(41, 151, 255, 0.12);
      border-radius: 14px;
    }
    .stack-label {
      font-size: 11px;
      letter-spacing: 0.12em;
      color: #86868b;
      font-weight: 600;
      display: block;
      margin-bottom: 10px;
    }
    .stack-items {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
    }
    .stack-item {
      color: #f5f5f7;
      font-size: 15px;
      font-weight: 600;
    }
    .stack-dot {
      width: 4px;
      height: 4px;
      background: #2997ff;
      border-radius: 50%;
    }

    /* Tiers Grid */
    .tiers-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      max-width: 1100px;
      width: 100%;
    }
    .tier-card {
      background: rgba(255, 255, 255, 0.05);
      border-radius: 18px;
      backdrop-filter: blur(20px);
      padding: 36px 28px;
      display: flex;
      flex-direction: column;
      box-shadow: 0 2px 14px 0 rgba(44, 62, 80, 0.14);
      border: 1px solid rgba(255, 255, 255, 0.06);
    }
    .tier-card.featured {
      background: rgba(41, 151, 255, 0.08);
      border: 1px solid rgba(41, 151, 255, 0.2);
      transform: scale(1.02);
    }
    .tier-badge {
      font-size: 11px;
      letter-spacing: 0.1em;
      color: #86868b;
      text-transform: uppercase;
      margin-bottom: 12px;
      font-weight: 600;
    }
    .tier-badge.popular {
      color: #2997ff;
    }
    .tier-card h2 {
      font-size: 28px;
      font-weight: 600;
      margin-bottom: 8px;
    }
    .tier-tagline {
      font-size: 15px;
      color: #86868b;
      font-weight: 600;
      margin-bottom: 12px;
      letter-spacing: 0.02em;
    }
    .tier-problem {
      font-size: 16px;
      color: #a1a1a6;
      line-height: 1.5;
      margin-bottom: 0;
    }
    .divider {
      height: 1px;
      background: rgba(255, 255, 255, 0.1);
      margin: 20px 0;
    }
    .tier-card h3 {
      font-size: 14px;
      color: #86868b;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 12px;
    }
    .tier-features {
      list-style: none;
      padding: 0;
      margin: 0;
      flex-grow: 1;
    }
    .tier-features li {
      padding: 8px 0;
      color: #d2d2d7;
      font-size: 15px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      padding-left: 16px;
      position: relative;
    }
    .tier-features li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
      width: 6px;
      height: 6px;
      background: #2997ff;
      border-radius: 50%;
    }
    .tier-features li:last-child {
      border-bottom: none;
    }
    .tier-ideal {
      font-size: 14px;
      color: #a1a1a6;
      line-height: 1.5;
      margin-bottom: 20px;
    }
    .tier-ideal strong {
      color: #d2d2d7;
    }
    .cta-button {
      display: inline-block;
      text-align: center;
      padding: 14px 24px;
      background: #2997ff;
      color: white;
      border-radius: 12px;
      text-decoration: none;
      font-size: 16px;
      font-weight: 600;
      transition: opacity 0.3s;
    }
    .cta-button:hover {
      opacity: 0.8;
    }

    /* Process Section */
    .process-section {
      max-width: 900px;
      width: 100%;
      margin-top: 100px;
      text-align: center;
    }
    .process-section h2 {
      font-size: 36px;
      font-weight: 600;
      margin-bottom: 48px;
    }
    .process-steps {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }
    .step {
      text-align: center;
    }
    .step-number {
      font-size: 32px;
      font-weight: 700;
      color: #2997ff;
      display: block;
      margin-bottom: 12px;
    }
    .step h4 {
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 8px;
    }
    .step p {
      font-size: 14px;
      color: #a1a1a6;
      line-height: 1.5;
    }

    @media (max-width: 768px) {
      .services-container {
        padding: 80px 16px 60px;
      }
      .services-header h1 {
        font-size: 32px;
      }
      .services-header p {
        font-size: 17px;
      }
      .tiers-grid {
        grid-template-columns: 1fr;
      }
      .tier-card.featured {
        transform: none;
      }
      .process-steps {
        grid-template-columns: repeat(2, 1fr);
        gap: 32px;
      }
      .process-section h2 {
        font-size: 28px;
      }
    }
  </style>
</MainLayout>
