---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="About | Nick Ruffin">
  <div class="about-container">
    <div class="about-content">
      <span class="about-tag">ABOUT</span>
      <h1>Nick Ruffin</h1>
      <p class="about-subtitle">Data Monetization Consultant | Advisory + Implementation</p>

      <div class="about-sections">
        <div class="about-section">
          <h2>What I Do</h2>
          <p>
            I help healthcare and pharma companies turn raw data into compliant,
            deliverable products that generate recurring revenue. Most companies
            know their data is valuable — they get stuck between "we have data"
            and "we have a data product." I bridge that gap.
          </p>
          <p>
            I built the data monetization platform at a national pharmacy services
            company — from raw claims data through expert determination,
            Datavant tokenization, to automated Snowflake + AWS delivery. That
            platform now generates $7M+ annually, processes 4.8 billion
            de-identified records, and delivers to 50+ clients with zero manual
            intervention.
          </p>
          <p>
            Now I help other organizations replicate that process with their own data.
          </p>
        </div>

        <div class="about-section">
          <h2>How I Work</h2>
          <ul class="about-list">
            <li><strong>Advisory</strong> — architecture, vendor selection, compliance strategy, process design</li>
            <li><strong>Implementation</strong> — full pipeline build from raw data to client delivery</li>
            <li><strong>De-identification</strong> — expert determination setup, HIPAA compliance, ongoing support</li>
            <li><strong>Tokenization</strong> — Datavant integration for cross-dataset linking at scale</li>
            <li><strong>Delivery automation</strong> — Airflow orchestration, S3 transfers, zero-touch pipelines</li>
          </ul>
        </div>

        <div class="about-section">
          <h2>Technical Expertise</h2>
          <div class="tech-grid">
            <div class="tech-category">
              <h3>Data Platforms</h3>
              <p>Snowflake, AWS (S3, Lambda, MWAA), Airflow, Terraform</p>
            </div>
            <div class="tech-category">
              <h3>Pipeline</h3>
              <p>Python, SQL, ETL/ELT, de-identification, Datavant tokenization, HIPAA compliance</p>
            </div>
            <div class="tech-category">
              <h3>Delivery</h3>
              <p>Automated client transfers, data quality monitoring, infrastructure as code</p>
            </div>
          </div>
        </div>

        <div class="about-section">
          <h2>Background</h2>
          <p>
            Before building the data monetization platform, I served as Director
            of Engineering at Nimble Solutions — growing a department of 16+ engineers
            across the US and India, leading technology due diligence for 4 acquisitions,
            and delivering enterprise systems that transformed business operations.
          </p>
        </div>
      </div>

      <div class="about-cta">
        <a href="/contact" class="cta-button">Start a Conversation</a>
        <a href="/case-studies" class="secondary-link">See the case study ></a>
      </div>
    </div>
  </div>

  <style>
    .about-container {
      min-height: 100vh;
      background: #000;
      color: #f5f5f7;
      padding: 110px 24px 80px;
      display: flex;
      justify-content: center;
    }
    .about-content {
      max-width: 680px;
      width: 100%;
    }
    .about-tag {
      font-size: 13px;
      letter-spacing: 0.13em;
      color: #2997ff;
      margin-bottom: 22px;
      display: block;
      font-weight: 600;
    }
    .about-content h1 {
      font-size: 48px;
      font-weight: 600;
      margin-bottom: 8px;
    }
    .about-subtitle {
      font-size: 21px;
      color: #86868b;
      margin-bottom: 48px;
    }

    .about-sections {
      display: flex;
      flex-direction: column;
      gap: 40px;
    }
    .about-section h2 {
      font-size: 24px;
      font-weight: 600;
      margin-bottom: 16px;
      color: #f5f5f7;
    }
    .about-section p {
      font-size: 17px;
      color: #a1a1a6;
      line-height: 1.7;
      margin-bottom: 12px;
    }
    .about-section p:last-child {
      margin-bottom: 0;
    }

    .about-list {
      list-style: none;
      padding: 0;
    }
    .about-list li {
      padding: 10px 0;
      padding-left: 20px;
      position: relative;
      font-size: 17px;
      color: #a1a1a6;
      line-height: 1.5;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    .about-list li:last-child {
      border-bottom: none;
    }
    .about-list li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
      width: 6px;
      height: 6px;
      background: #2997ff;
      border-radius: 50%;
    }
    .about-list li strong {
      color: #f5f5f7;
    }

    .tech-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    .tech-category {
      background: rgba(255, 255, 255, 0.04);
      border-radius: 14px;
      padding: 20px;
      border: 1px solid rgba(255, 255, 255, 0.06);
    }
    .tech-category h3 {
      font-size: 14px;
      color: #2997ff;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 8px;
      font-weight: 600;
    }
    .tech-category p {
      font-size: 15px;
      color: #a1a1a6;
      line-height: 1.5;
      margin-bottom: 0;
    }

    .about-cta {
      margin-top: 60px;
      display: flex;
      align-items: center;
      gap: 24px;
    }
    .cta-button {
      display: inline-block;
      padding: 14px 32px;
      background: #2997ff;
      color: white;
      border-radius: 30px;
      text-decoration: none;
      font-size: 17px;
      font-weight: 600;
      transition: opacity 0.3s;
    }
    .cta-button:hover {
      opacity: 0.8;
    }
    .secondary-link {
      color: #2997ff;
      text-decoration: none;
      font-size: 17px;
      font-weight: 500;
      transition: opacity 0.3s;
    }
    .secondary-link:hover {
      opacity: 0.7;
    }

    @media (max-width: 768px) {
      .about-content h1 {
        font-size: 36px;
      }
      .about-subtitle {
        font-size: 18px;
      }
      .tech-grid {
        grid-template-columns: 1fr;
      }
      .about-cta {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
</MainLayout>
