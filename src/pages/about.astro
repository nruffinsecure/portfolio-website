---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="About | Nick Ruffin">
  <div class="about-container">
    <canvas id="molecule-canvas"></canvas>
    <div class="about-content">
      <div class="about-header">
        <div class="about-header-text">
          <span class="about-tag reveal">ABOUT</span>
          <h1 class="reveal reveal-delay-1">Nick Ruffin</h1>
          <p class="about-subtitle reveal reveal-delay-2">Manager, Data Product Engineering &middot; RedSail Technologies</p>
          <p class="about-tagline reveal reveal-delay-3">St. Louis, MO &middot; Open to opportunities in healthcare data</p>
        </div>
        <div class="about-portrait reveal reveal-delay-2">
          <div class="portrait-frame">
            <img src="/images/nick.jpg" alt="Nick Ruffin" loading="eager" />
          </div>
        </div>
      </div>

      <div class="about-sections">
        <div class="about-section reveal">
          <h2>What I do</h2>
          <p>I lead the team that builds and runs RedSail's clinical data monetization platform &mdash; a $9M ARR product on top of 6 billion de-identified pharmacy claims records, delivering to enterprise clients across pharma, life sciences, and real-world evidence.</p>
          <p>I architected the platform and now lead the team building on top of it. The work spans Snowflake, AWS (S3, Lambda, MWAA), Airflow, Terraform, and Datavant tokenization &mdash; from raw upstream data through expert determination to automated client delivery. I'm currently leading the V2 tokenization rebuild on MWAA V3.</p>
        </div>

        <div class="about-section reveal">
          <h2>How I lead</h2>
          <ul class="about-list">
            <li><strong>Product-eng ownership</strong> &mdash; architecture, delivery, and day-to-day execution on the platform.</li>
            <li><strong>Cross-team coordination</strong> &mdash; infra, analytics, legal/compliance, and external vendors (Datavant, AWS).</li>
            <li><strong>Client-facing</strong> &mdash; SLAs, audit readiness, expert determination requirements, contract delivery.</li>
            <li><strong>Bias toward shipping</strong> &mdash; I bring my own hands to the keyboard when it accelerates the team. Same-week feedback loops.</li>
            <li><strong>Public artifacts</strong> &mdash; case studies, architecture diagrams, post-incident docs that travel beyond the team.</li>
          </ul>
        </div>

        <div class="about-section reveal">
          <h2>Where I've led before</h2>
          <p>Before RedSail, I was Director of Full Stack Development at Nimble Solutions &mdash; hand-picked by the CIO to lead three separate engineering teams across the US and Hyderabad. Owned technology due diligence for four acquisitions, traveled to India to integrate an acquired team, and built enterprise systems that transformed how the business ran.</p>
        </div>

        <div class="about-section reveal">
          <h2>Stack I lead with</h2>
          <div class="tech-grid">
            <div class="tech-category">
              <h3>Cloud &amp; Orchestration</h3>
              <p>AWS (S3, Lambda, MWAA V3), Airflow, Terraform, IAM trust policy work</p>
            </div>
            <div class="tech-category">
              <h3>Data Platform</h3>
              <p>Snowflake at 6B-record scale, Python, SQL, ETL/ELT, clustering &amp; cost design</p>
            </div>
            <div class="tech-category">
              <h3>Compliance &amp; Privacy</h3>
              <p>HIPAA, expert determination, Datavant tokenization, multi-tenant isolation</p>
            </div>
          </div>
        </div>

        <div class="about-section reveal">
          <h2>What I'm looking for</h2>
          <p>The right opportunity in healthcare data &mdash; pharma, life sciences, real-world evidence, payer/PBM analytics, or any company that makes money on clinical data products. I'm interested in roles where I own a data product or platform end-to-end and lead the team behind it. Remote-first, US-based.</p>
          <p>If that's you, the fastest path is a LinkedIn DM. I read every one.</p>
        </div>
      </div>

      <div class="about-cta reveal">
        <a href="https://www.linkedin.com/in/nicholas-ruffin-a9b767102" target="_blank" rel="noopener" class="cta-button">Connect on LinkedIn</a>
        <a href="/case-studies" class="secondary-link">See the architecture &rarr;</a>
      </div>
    </div>
  </div>

  <script>
    function initMolecules() {
      const canvas = document.getElementById('molecule-canvas') as HTMLCanvasElement;
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;
      let w = canvas.width = window.innerWidth;
      let h = canvas.height = canvas.parentElement!.scrollHeight;
      let animId: number;

      interface Atom { x: number; y: number; vx: number; vy: number; radius: number; hue: number; }
      const atoms: Atom[] = [];
      const count = Math.min(35, Math.floor(w * h / 30000));

      for (let i = 0; i < count; i++) {
        atoms.push({
          x: Math.random() * w, y: Math.random() * h,
          vx: (Math.random() - 0.5) * 0.4, vy: (Math.random() - 0.5) * 0.4,
          radius: 3 + Math.random() * 4,
          hue: 265 + Math.random() * 35,
        });
      }

      function draw() {
        ctx!.clearRect(0, 0, w, h);
        // Draw bonds
        for (let i = 0; i < atoms.length; i++) {
          for (let j = i + 1; j < atoms.length; j++) {
            const dx = atoms[i].x - atoms[j].x;
            const dy = atoms[i].y - atoms[j].y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < 150) {
              ctx!.beginPath();
              ctx!.moveTo(atoms[i].x, atoms[i].y);
              ctx!.lineTo(atoms[j].x, atoms[j].y);
              ctx!.strokeStyle = `hsla(280, 60%, 60%, ${0.15 * (1 - dist / 150)})`;
              ctx!.lineWidth = 1;
              ctx!.stroke();
            }
          }
        }
        // Draw atoms
        for (const a of atoms) {
          a.x += a.vx; a.y += a.vy;
          if (a.x < 0 || a.x > w) a.vx *= -1;
          if (a.y < 0 || a.y > h) a.vy *= -1;

          const glow = ctx!.createRadialGradient(a.x, a.y, 0, a.x, a.y, a.radius * 4);
          glow.addColorStop(0, `hsla(${a.hue}, 80%, 70%, 0.4)`);
          glow.addColorStop(1, `hsla(${a.hue}, 80%, 60%, 0)`);
          ctx!.fillStyle = glow;
          ctx!.beginPath();
          ctx!.arc(a.x, a.y, a.radius * 4, 0, Math.PI * 2);
          ctx!.fill();

          ctx!.beginPath();
          ctx!.arc(a.x, a.y, a.radius, 0, Math.PI * 2);
          ctx!.fillStyle = `hsla(${a.hue}, 90%, 75%, 0.7)`;
          ctx!.fill();
        }
        animId = requestAnimationFrame(draw);
      }
      draw();
      window.addEventListener('resize', () => { w = canvas.width = window.innerWidth; h = canvas.height = canvas.parentElement!.scrollHeight; });
      document.addEventListener('astro:before-swap', () => cancelAnimationFrame(animId));
    }
    initMolecules();
    document.addEventListener('astro:after-swap', initMolecules);
  </script>

  <style>
    .about-container {
      min-height: 100vh;
      background: var(--background-color);
      color: var(--text-color);
      padding: 110px 24px 80px;
      display: flex;
      justify-content: center;
      position: relative;
    }
    #molecule-canvas { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; }
    .about-content { max-width: 920px; width: 100%; position: relative; z-index: 1; }
    .about-header {
      display: grid;
      grid-template-columns: 1fr 240px;
      gap: 48px;
      align-items: center;
      margin-bottom: 60px;
    }
    .about-header-text { display: flex; flex-direction: column; }
    .about-tag { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.15em; color: var(--primary-color); margin-bottom: 22px; display: block; }
    .about-content h1 { font-size: 48px; font-weight: 700; margin-bottom: 8px; letter-spacing: -0.02em; }
    .about-subtitle { font-size: 18px; color: var(--text-muted); margin-bottom: 14px; }
    .about-tagline {
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-muted);
      opacity: 0.85;
    }

    .about-portrait { display: flex; justify-content: center; }
    .portrait-frame {
      width: 220px;
      height: 220px;
      border-radius: 50%;
      overflow: hidden;
      position: relative;
      padding: 3px;
      background: linear-gradient(135deg, rgba(168, 85, 247, 0.5) 0%, rgba(124, 58, 237, 0.2) 100%);
      box-shadow: 0 12px 40px rgba(168, 85, 247, 0.18), 0 0 0 1px rgba(168, 85, 247, 0.18);
    }
    .portrait-frame::before {
      content: "";
      position: absolute;
      inset: -2px;
      background: conic-gradient(from 0deg, rgba(168, 85, 247, 0.45), rgba(124, 58, 237, 0.0), rgba(168, 85, 247, 0.45));
      border-radius: 50%;
      z-index: -1;
      animation: portraitGlow 8s linear infinite;
    }
    .portrait-frame img {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      object-fit: cover;
      object-position: center 25%;
      display: block;
    }
    @keyframes portraitGlow {
      to { transform: rotate(360deg); }
    }
    .about-sections { display: flex; flex-direction: column; gap: 40px; }
    .about-section h2 { font-size: 22px; font-weight: 600; margin-bottom: 16px; color: var(--text-color); }
    .about-section p { font-size: 16px; color: var(--text-muted); line-height: 1.8; margin-bottom: 12px; }
    .about-list { list-style: none; padding: 0; }
    .about-list li { padding: 12px 0; padding-left: 20px; position: relative; font-size: 16px; color: var(--text-muted); line-height: 1.5; border-bottom: 1px solid rgba(168, 85, 247, 0.08); }
    .about-list li:last-child { border-bottom: none; }
    .about-list li::before { content: ""; position: absolute; left: 0; top: 50%; transform: translateY(-50%); width: 6px; height: 6px; background: var(--primary-color); border-radius: 50%; }
    .about-list li strong { color: var(--text-color); }
    .tech-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
    .tech-category { background: var(--card-bg); border-radius: 12px; padding: 20px; border: 1px solid var(--card-border); transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s; }
    .tech-category:hover { border-color: rgba(168, 85, 247, 0.3); box-shadow: 0 4px 20px rgba(168, 85, 247, 0.1); transform: translateY(-2px); }
    .tech-category h3 { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--primary-color); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px; }
    .tech-category p { font-size: 14px; color: var(--text-muted); line-height: 1.5; margin-bottom: 0; }
    .about-cta { margin-top: 60px; display: flex; align-items: center; gap: 24px; }
    .cta-button { display: inline-block; padding: 14px 32px; background: linear-gradient(135deg, #a855f7 0%, #7c3aed 100%); color: white; border-radius: 10px; text-decoration: none; font-size: 16px; font-weight: 600; transition: all 0.3s; box-shadow: 0 4px 24px var(--primary-glow); }
    .cta-button:hover { transform: translateY(-2px); box-shadow: 0 8px 40px rgba(168, 85, 247, 0.5); }
    .secondary-link { color: var(--primary-color); text-decoration: none; font-size: 16px; font-weight: 500; transition: opacity 0.3s; }
    .secondary-link:hover { opacity: 0.7; }
    @media (max-width: 768px) {
      .about-content h1 { font-size: 36px; }
      .tech-grid { grid-template-columns: 1fr; }
      .about-cta { flex-direction: column; align-items: flex-start; }
      .about-header { grid-template-columns: 1fr; gap: 28px; text-align: center; margin-bottom: 40px; }
      .about-header-text { align-items: center; }
      .portrait-frame { width: 180px; height: 180px; }
    }
  </style>
</MainLayout>
