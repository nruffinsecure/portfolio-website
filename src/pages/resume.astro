---
import MainLayout from "../layouts/MainLayout.astro";
---

<!-- Resume Page: Designed for Print-to-PDF -->
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Nicholas Ruffin - Senior Clinical Data Engineer - Resume</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Merriweather:wght@300;400;700&display=swap"
            rel="stylesheet"
        />
        <style>
            :root {
                --text-primary: #111827;
                --text-secondary: #4b5563;
                --accent: #2563eb; /* Professional Blue */
                --border: #e5e7eb;
            }

            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: "Inter", sans-serif;
                line-height: 1.5;
                color: var(--text-primary);
                background: #fff;
                max-width: 8.5in; /* US Letter Width */
                margin: 0 auto;
                padding: 0.5in; /* Print margins */
            }

            header {
                border-bottom: 2px solid var(--text-primary);
                padding-bottom: 1.5rem;
                margin-bottom: 2rem;
                display: flex;
                justify-content: space-between;
                align-items: flex-start;
            }

            .header-left h1 {
                font-size: 2.25rem; /* 36px */
                font-weight: 800;
                letter-spacing: -0.02em;
                margin-bottom: 0.25rem;
                text-transform: uppercase;
            }

            .header-left h2 {
                font-size: 1.1rem;
                font-weight: 500;
                color: var(--text-secondary);
                letter-spacing: 0.05em;
                text-transform: uppercase;
            }

            .header-right {
                text-align: right;
                font-size: 0.9rem;
                color: var(--text-secondary);
            }

            .header-right a {
                color: var(--text-secondary);
                text-decoration: none;
                display: block;
                margin-bottom: 0.25rem;
            }

            section {
                margin-bottom: 2rem;
            }

            .section-title {
                font-size: 1rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.05em;
                color: var(--accent);
                border-bottom: 1px solid var(--border);
                padding-bottom: 0.5rem;
                margin-bottom: 1rem;
            }

            .summary-text {
                font-size: 0.95rem;
                color: var(--text-secondary);
                line-height: 1.6;
            }

            .skills-grid {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 0.5rem 2rem;
                font-size: 0.9rem;
            }

            .skill-item {
                display: flex;
                align-items: baseline;
            }

            .skill-item strong {
                font-weight: 600;
                margin-right: 0.5rem;
                color: var(--text-primary);
            }

            .job-entry {
                margin-bottom: 1.5rem;
            }

            .job-header {
                display: flex;
                justify-content: space-between;
                align-items: baseline;
                margin-bottom: 0.5rem;
            }

            .job-title-row {
                display: flex;
                align-items: baseline;
                gap: 0.75rem;
            }

            .job-role {
                font-size: 1.1rem;
                font-weight: 700;
                color: var(--text-primary);
            }

            .job-company {
                font-size: 1rem;
                font-weight: 500;
                color: var(--text-secondary);
            }

            .job-date {
                font-size: 0.9rem;
                font-weight: 500;
                color: var(--text-secondary);
            }

            .job-bullets {
                list-style: none;
                padding: 0;
            }

            .job-bullets li {
                position: relative;
                padding-left: 1.2rem;
                margin-bottom: 0.4rem;
                font-size: 0.95rem;
                color: #374151;
                line-height: 1.5;
            }

            .job-bullets li::before {
                content: "•";
                position: absolute;
                left: 0;
                color: var(--accent);
                font-weight: bold;
            }

            .education-entry {
                display: flex;
                justify-content: space-between;
                font-size: 0.95rem;
            }

            /* Print Optimization */
            @media print {
                @page {
                    margin: 0.5in;
                    size: letter;
                }
                body {
                    width: 100%;
                    margin: 0;
                    padding: 0;
                    print-color-adjust: exact;
                    -webkit-print-color-adjust: exact;
                }
                /* Hide web-only elements if any existed */
                a {
                    text-decoration: none;
                    color: inherit;
                }
            }
        </style>
    </head>
    <body>
        <header>
            <div class="header-left">
                <h1>Nicholas Ruffin</h1>
                <h2>Senior Clinical Data Engineer</h2>
            </div>
            <div class="header-right">
                <div>Maryland Heights, MO</div>
                <a href="tel:8437939770">(843) 793-9770</a>
                <a href="mailto:nruffinsecure@gmail.com"
                    >nruffinsecure@gmail.com</a
                >
                <a href="https://linkedin.com/in/nicholas-ruffin-a9b767102"
                    >linkedin.com/in/nicholas-ruffin</a
                >
            </div>
        </header>

        <section>
            <h3 class="section-title">Professional Summary</h3>
            <p class="summary-text">
                Senior Clinical Data Engineer with 12+ years of technology
                experience, focused on high-scale data architecture. Proven
                expertise designing enterprise data platforms processing <strong
                    >4.8B+ daily records</strong
                >
                and generating <strong>$7M+ annual revenue</strong>. Specialized
                in HIPAA-compliant data tokenization, clinical data pipelines,
                and cloud-native Snowflake/AWS solutions. Expert in optimizing
                complex ETL/ELT workflows and implementing robust data
                governance frameworks.
            </p>
        </section>

        <section>
            <h3 class="section-title">Technical Skills</h3>
            <div class="skills-grid">
                <div class="skill-item">
                    <strong>Core:</strong> SQL, Python, ETL/ELT Pipeline Design
                </div>
                <div class="skill-item">
                    <strong>Cloud & Infra:</strong> AWS (MWAA, S3, Lambda, IAM), Terraform
                </div>
                <div class="skill-item">
                    <strong>Data Platform:</strong> Snowflake (Procs, Streams), Kafka,
                    AWS Glue
                </div>
                <div class="skill-item">
                    <strong>Orchestration:</strong> Apache Airflow, GitHub Actions
                    (CI/CD)
                </div>
                <div class="skill-item">
                    <strong>Governance:</strong> HIPAA Compliance, Datavant Tokenization
                </div>
                <div class="skill-item">
                    <strong>Tools:</strong> Docker, Git, Claude AI-Assisted Dev
                </div>
            </div>
        </section>

        <section>
            <h3 class="section-title">Experience</h3>

            <div class="job-entry">
                <div class="job-header">
                    <div class="job-title-row">
                        <span class="job-role"
                            >Senior Clinical Data Engineer</span
                        >
                        <span class="job-company">| RedSail Technologies</span>
                    </div>
                    <span class="job-date">Feb 2025 - Present</span>
                </div>
                <ul class="job-bullets">
                    <li>
                        Architected a data monetization platform driving <strong
                            >$7M+ ARR</strong
                        >
                        by designing secure PII tokenization workflows (Snowflake
                        + Datavant), enabling pharmaceutical clients to access privacy-compliant
                        clinical datasets.
                    </li>
                    <li>
                        Engineered de-identification pipelines processing <strong
                            >4.8 billion records daily</strong
                        > (3M+ transactions/hour), ensuring strict HIPAA compliance
                        for downstream data science initiatives.
                    </li>
                    <li>
                        Optimized Snowflake architecture (Materialized Views,
                        Stored Procs) to reduce query latency by <strong
                            >40%</strong
                        >, eliminating critical manual bottlenecks.
                    </li>
                    <li>
                        Built a Python/Airflow orchestration framework deployed
                        via GitHub Actions, automating <strong
                            >50+ daily workflows</strong
                        > for seamless S3 extraction and ETL processing.
                    </li>
                    <li>
                        Implemented automated Health Checks (Snowflake Tasks +
                        Airflow Metrics) achieving <strong
                            >99.5% pipeline uptime</strong
                        >.
                    </li>
                </ul>
            </div>

            <div class="job-entry">
                <div class="job-header">
                    <div class="job-title-row">
                        <span class="job-role"
                            >Lead Data Integration Developer</span
                        >
                        <span class="job-company">| Nimble Solutions</span>
                    </div>
                    <span class="job-date">Aug 2021 - Jan 2025</span>
                </div>
                <ul class="job-bullets">
                    <li>
                        Led development of QUARC AR workflow solution using
                        microservices (.NET, GraphQL), increasing case
                        throughput by <strong>32+ cases per rep</strong>.
                    </li>
                    <li>
                        Engineered the integration of <strong
                            >50+ data sources</strong
                        > into a unified enterprise workflow, designing API orchestration
                        patterns for high reliability.
                    </li>
                    <li>
                        Reduced deployment time by <strong>60%</strong> through CI/CD
                        optimization (Azure DevOps, GitHub Actions), achieving 90%+
                        test code coverage.
                    </li>
                    <li>
                        Managed 5+ engineers, establishing technical standards
                        for cloud infrastructure and mentoring the team on best
                        practices.
                    </li>
                </ul>
            </div>

            <div class="job-entry">
                <div class="job-header">
                    <div class="job-title-row">
                        <span class="job-role">Senior Full Stack Developer</span
                        >
                        <span class="job-company">| Core & Main</span>
                    </div>
                    <span class="job-date">Jun 2017 - Aug 2021</span>
                </div>
                <ul class="job-bullets">
                    <li>
                        Developed enterprise data applications using C#/.NET and
                        SQL, supporting <strong
                            >200+ concurrent corporate users</strong
                        >.
                    </li>
                </ul>
            </div>
        </section>

        <section>
            <h3 class="section-title">Education</h3>
            <div class="education-entry">
                <span
                    ><strong>Bachelor of Science, Information Technology</strong
                    ></span
                >
                <span>University of Phoenix</span>
            </div>
        </section>
    </body>
</html>
