---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/Hero.astro";
---

<MainLayout title="Nick Ruffin | Data Engineering Leadership">
  <div class="container">
    <Hero />

    <!-- Leadership Profile -->
    <section class="services-section">
      <div class="services-content">
        <span class="section-tag">LEADERSHIP PROFILE</span>
        <h3>Engineering leadership that drives business results</h3>
        <div class="services-grid">
          <div class="service-card">
            <div class="card-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#2997ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <h4>Team Leadership</h4>
            <p>Built and managed 16+ engineers across US and offshore (Hyderabad). Led technology due diligence for 4 acquisitions and integrated teams across borders.</p>
            <a href="/experience" class="card-link">See results ></a>
          </div>
          <div class="service-card">
            <div class="card-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#2997ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            </div>
            <h4>Technical Strategy</h4>
            <p>Architected a data monetization platform generating $7M+ annually. Built de-identification pipelines processing 4.8B records with full HIPAA compliance.</p>
            <a href="/experience" class="card-link">See results ></a>
          </div>
          <div class="service-card">
            <div class="card-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#2997ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>
            </div>
            <h4>Enterprise Delivery</h4>
            <p>De-identification pipelines processing 4.8B records. Automated delivery to 50+ external clients with zero manual intervention.</p>
            <a href="/experience" class="card-link">See results ></a>
          </div>
        </div>
      </div>
    </section>

    <!-- Results / Social Proof -->
    <section class="results-section">
      <div class="results-content">
        <span class="section-tag">TRACK RECORD</span>
        <h3>Built at enterprise scale</h3>
        <div class="results-grid">
          <div class="result-item">
            <span class="result-number">$7M+</span>
            <span class="result-label">Revenue generated from data monetization platforms</span>
          </div>
          <div class="result-item">
            <span class="result-number">4.8B</span>
            <span class="result-label">Records de-identified and delivered</span>
          </div>
          <div class="result-item">
            <span class="result-number">40+</span>
            <span class="result-label">Hours saved per month through pipeline automation</span>
          </div>
          <div class="result-item">
            <span class="result-number">50+</span>
            <span class="result-label">External client data deliveries</span>
          </div>
        </div>
        <a href="/experience" class="results-cta">See detailed results ></a>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <div class="cta-content">
        <h3>Looking for engineering leadership that delivers results?</h3>
        <p>I'm always interested in conversations about building great data teams and solving complex infrastructure challenges.</p>
        <a href="/contact" class="cta-button">Get in Touch</a>
      </div>
    </section>
  </div>
</MainLayout>

<style>
  .container {
    width: 100%;
    position: relative;
    overflow-x: hidden;
    margin: 0;
    padding: 0;
  }

  .section-tag {
    font-size: 12px;
    letter-spacing: 0.1em;
    color: #2997ff;
    margin-bottom: 16px;
    display: block;
    font-weight: 600;
  }

  /* Services Section */
  .services-section {
    width: 100%;
    background: rgba(0, 0, 0, 0.85);
    padding: 80px 24px;
    color: #f5f5f7;
    display: flex;
    justify-content: center;
  }
  .services-content {
    max-width: 1000px;
    margin: 0 auto;
    text-align: center;
  }
  .services-content h3 {
    font-size: 2rem;
    font-weight: 600;
    margin-bottom: 3rem;
    color: #f5f5f7;
  }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .service-card {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 18px;
    padding: 32px 24px;
    text-align: left;
    transition: transform 0.3s, background 0.3s;
    backdrop-filter: blur(10px);
  }
  .service-card:hover {
    transform: translateY(-4px);
    background: rgba(255, 255, 255, 0.08);
  }
  .card-icon {
    margin-bottom: 16px;
  }
  .service-card h4 {
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 12px;
    color: #f5f5f7;
  }
  .service-card p {
    font-size: 1rem;
    color: #a1a1a6;
    line-height: 1.6;
    margin-bottom: 16px;
  }
  .card-link {
    color: #2997ff;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: opacity 0.3s;
  }
  .card-link:hover {
    opacity: 0.7;
  }

  /* Results Section */
  .results-section {
    width: 100%;
    background: #000;
    padding: 80px 24px;
    color: #f5f5f7;
    display: flex;
    justify-content: center;
  }
  .results-content {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }
  .results-content h3 {
    font-size: 2rem;
    font-weight: 600;
    margin-bottom: 3rem;
  }
  .results-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    margin-bottom: 2.5rem;
  }
  .result-item {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .result-number {
    font-size: 2.5rem;
    font-weight: 700;
    color: #2997ff;
  }
  .result-label {
    font-size: 0.95rem;
    color: #a1a1a6;
    line-height: 1.4;
  }
  .results-cta {
    color: #2997ff;
    text-decoration: none;
    font-size: 1.05rem;
    font-weight: 500;
    transition: opacity 0.3s;
  }
  .results-cta:hover {
    opacity: 0.7;
  }

  /* CTA Section */
  .cta-section {
    width: 100%;
    background: rgba(41, 151, 255, 0.06);
    padding: 80px 24px;
    display: flex;
    justify-content: center;
  }
  .cta-content {
    max-width: 600px;
    text-align: center;
  }
  .cta-content h3 {
    font-size: 2rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: #f5f5f7;
  }
  .cta-content p {
    font-size: 1.1rem;
    color: #a1a1a6;
    margin-bottom: 2rem;
    line-height: 1.6;
  }
  .cta-button {
    display: inline-block;
    padding: 1rem 2.5rem;
    background: #2997ff;
    color: white;
    border-radius: 30px;
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: 600;
    transition: opacity 0.3s;
  }
  .cta-button:hover {
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
    .results-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
    .services-content h3,
    .results-content h3,
    .cta-content h3 {
      font-size: 1.5rem;
    }
    .result-number {
      font-size: 2rem;
    }
    .services-section,
    .results-section,
    .cta-section {
      padding: 56px 16px;
    }
  }
</style>
