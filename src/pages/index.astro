---
import MainLayout from "../layouts/MainLayout.astro";
import Hero from "../components/Hero.astro";
---

<MainLayout title="Nick Ruffin | Engineering Leader">
  <div class="container">
    <Hero />

    <section class="services-section">
      <div class="services-content">
        <span class="section-tag reveal">WHAT I BUILD</span>
        <h3 class="reveal reveal-delay-1">End-to-end data platforms at enterprise scale</h3>
        <div class="services-grid">
          <div class="service-card reveal reveal-delay-1">
            <div class="card-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>
            </div>
            <h4>De-identification &amp; Compliance</h4>
            <p>Expert determination, HIPAA-compliant pipelines, and privacy infrastructure that makes healthcare data safe to use at scale.</p>
            <a href="/case-studies" class="card-link">See the case study &rarr;</a>
          </div>
          <div class="service-card reveal reveal-delay-2">
            <div class="card-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            </div>
            <h4>Tokenization &amp; Linking</h4>
            <p>Datavant integration across billions of records — privacy-preserving tokens that enable cross-dataset analytics without re-identification.</p>
            <a href="/case-studies" class="card-link">See the case study &rarr;</a>
          </div>
          <div class="service-card reveal reveal-delay-3">
            <div class="card-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <h4>Pipeline &amp; Delivery</h4>
            <p>Snowflake + AWS infrastructure with Airflow orchestration — 50+ automated daily workflows with zero manual intervention.</p>
            <a href="/case-studies" class="card-link">See the case study &rarr;</a>
          </div>
        </div>
      </div>
    </section>

    <section class="results-section">
      <div class="results-content">
        <span class="section-tag reveal">PROVEN RESULTS</span>
        <h3 class="reveal reveal-delay-1">Built and operating at scale</h3>
        <div class="results-grid reveal reveal-delay-2">
          <div class="result-item">
            <span class="result-number" data-counter="9" data-prefix="$" data-suffix="M+">$0</span>
            <span class="result-label">Revenue generated from data monetization platforms</span>
          </div>
          <div class="result-item">
            <span class="result-number" data-counter="6" data-suffix="B">0</span>
            <span class="result-label">Records de-identified and delivered</span>
          </div>
          <div class="result-item">
            <span class="result-number" data-counter="40" data-suffix="+">0</span>
            <span class="result-label">Hours saved per month through pipeline automation</span>
          </div>
          <div class="result-item">
            <span class="result-number" data-counter="50" data-suffix="+">0</span>
            <span class="result-label">Automated daily workflows</span>
          </div>
        </div>
        <a href="/case-studies" class="results-cta reveal reveal-delay-3">See the full case study &rarr;</a>
      </div>
    </section>

    <section class="cta-section">
      <div class="cta-content reveal">
        <h3>Looking for someone who's done this before?</h3>
        <p>I've built data monetization infrastructure from the ground up — de-identification, tokenization, automated delivery, all at enterprise scale. Let's talk.</p>
        <a href="/contact" class="cta-button">Get in Touch</a>
      </div>
    </section>
  </div>
</MainLayout>

<style>
  .container { width: 100%; position: relative; overflow-x: hidden; margin: 0; padding: 0; }
  .section-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--primary-color);
    margin-bottom: 16px;
    display: block;
    font-weight: 400;
  }

  .services-section {
    width: 100%;
    background: var(--background-color);
    padding: 100px 24px;
    color: var(--text-color);
    display: flex;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .services-section::before {
    content: "";
    position: absolute;
    top: 0;
    left: -50%;
    width: 200%;
    height: 100%;
    background: radial-gradient(ellipse at 30% 50%, rgba(168, 85, 247, 0.03) 0%, transparent 50%);
    animation: sectionGradient 15s ease-in-out infinite alternate;
    pointer-events: none;
  }
  @keyframes sectionGradient { 0% { transform: translateX(0); } 100% { transform: translateX(10%); } }

  .services-content { max-width: 1000px; margin: 0 auto; text-align: center; position: relative; z-index: 1; }
  .services-content h3 { font-size: 2.2rem; font-weight: 600; margin-bottom: 3.5rem; color: var(--text-color); }
  .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }

  .service-card {
    background: var(--card-bg);
    border-radius: 16px;
    padding: 32px 24px;
    text-align: left;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s;
    border: 1px solid var(--card-border);
    position: relative;
  }
  .service-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 8px 40px rgba(168, 85, 247, 0.12), 0 0 0 1px rgba(168, 85, 247, 0.2);
  }
  .card-icon { margin-bottom: 16px; color: var(--primary-color); }
  .service-card h4 { font-size: 1.2rem; font-weight: 600; margin-bottom: 12px; color: var(--text-color); }
  .service-card p { font-size: 0.95rem; color: var(--text-muted); line-height: 1.7; margin-bottom: 16px; }
  .card-link { color: var(--primary-color); text-decoration: none; font-size: 0.9rem; font-weight: 500; transition: opacity 0.3s; }
  .card-link:hover { opacity: 0.7; }

  .results-section {
    width: 100%;
    background: rgba(10, 0, 20, 0.8);
    padding: 100px 24px;
    color: var(--text-color);
    display: flex;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .results-content { max-width: 900px; margin: 0 auto; text-align: center; position: relative; z-index: 1; }
  .results-content h3 { font-size: 2.2rem; font-weight: 600; margin-bottom: 3.5rem; }
  .results-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px; margin-bottom: 2.5rem; }
  .result-item { display: flex; flex-direction: column; gap: 8px; }
  .result-number { font-size: 2.8rem; font-weight: 700; color: var(--primary-color); }
  .result-label { font-size: 0.9rem; color: var(--text-muted); line-height: 1.4; }
  .results-cta { color: var(--primary-color); text-decoration: none; font-size: 1rem; font-weight: 500; transition: opacity 0.3s; }
  .results-cta:hover { opacity: 0.7; }

  .cta-section {
    width: 100%;
    background: var(--primary-subtle);
    padding: 100px 24px;
    display: flex;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .cta-content { max-width: 600px; text-align: center; position: relative; z-index: 1; }
  .cta-content h3 { font-size: 2rem; font-weight: 600; margin-bottom: 1rem; color: var(--text-color); }
  .cta-content p { font-size: 1.05rem; color: var(--text-muted); margin-bottom: 2rem; line-height: 1.7; }
  .cta-button {
    display: inline-block;
    padding: 0.9rem 2.5rem;
    background: linear-gradient(135deg, #a855f7 0%, #7c3aed 100%);
    color: white;
    border-radius: 10px;
    text-decoration: none;
    font-size: 1rem;
    font-weight: 600;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 4px 24px var(--primary-glow);
  }
  .cta-button:hover { transform: translateY(-2px); box-shadow: 0 8px 40px rgba(168, 85, 247, 0.5); }

  @media (max-width: 768px) {
    .services-grid { grid-template-columns: 1fr; }
    .results-grid { grid-template-columns: repeat(2, 1fr); gap: 24px; }
    .services-content h3, .results-content h3, .cta-content h3 { font-size: 1.5rem; }
    .result-number { font-size: 2rem; }
    .services-section, .results-section, .cta-section { padding: 60px 16px; }
  }
</style>
