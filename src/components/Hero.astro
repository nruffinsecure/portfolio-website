---
---

<section class="hero-section">
  <canvas id="lab-canvas"></canvas>
  <div class="hero-fog"></div>
  <div class="hero-content">
    <span class="service-tag hero-reveal hero-reveal-1">Engineering Leader | Healthcare Data Platforms</span>
    <h1 class="hero-reveal hero-reveal-2">I build data platforms<br/>that generate revenue.</h1>
    <p class="hero-subtitle hero-reveal hero-reveal-3">$9M+ data monetization platform. 6 billion records. 50+ automated workflows.<br/>Snowflake, AWS, Airflow — from raw data to production at scale.</p>
    <div class="cta-wrapper hero-reveal hero-reveal-4">
      <a href="/case-studies" class="primary-cta">See My Work</a>
      <a href="/contact" class="secondary-cta">Get in Touch</a>
    </div>
  </div>
</section>

<script>
  function initLab() {
    const canvas = document.getElementById('lab-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let w = canvas.width = window.innerWidth;
    let h = canvas.height = window.innerHeight;
    let animationId: number;

    interface Vial {
      x: number;
      baseWidth: number;
      height: number;
      fillLevel: number;
      targetFill: number;
      fillSpeed: number;
      hue: number;
      saturation: number;
      neckWidth: number;
      bulbRadius: number;
      glowIntensity: number;
      pulsePhase: number;
      bubbles: Bubble[];
    }

    interface Bubble {
      x: number;
      y: number;
      radius: number;
      speed: number;
      wobblePhase: number;
      alpha: number;
    }

    const vials: Vial[] = [];
    const vialCount = Math.min(Math.floor(w / 120), 12);

    for (let i = 0; i < vialCount; i++) {
      const baseX = (w / (vialCount + 1)) * (i + 1) + (Math.random() * 40 - 20);
      const vialHeight = h * (0.35 + Math.random() * 0.3);
      const bw = 16 + Math.random() * 14;

      const vial: Vial = {
        x: baseX,
        baseWidth: bw,
        height: vialHeight,
        fillLevel: 0,
        targetFill: 0.4 + Math.random() * 0.5,
        fillSpeed: 0.001 + Math.random() * 0.002,
        hue: 265 + Math.random() * 40,
        saturation: 70 + Math.random() * 30,
        neckWidth: bw * 0.5,
        bulbRadius: bw * 1.2,
        glowIntensity: 0.5 + Math.random() * 0.5,
        pulsePhase: Math.random() * Math.PI * 2,
        bubbles: [],
      };

      // Create bubbles for this vial
      for (let b = 0; b < 4 + Math.floor(Math.random() * 4); b++) {
        vial.bubbles.push({
          x: vial.x + (Math.random() - 0.5) * bw * 0.6,
          y: h - Math.random() * vialHeight * 0.6,
          radius: 1.5 + Math.random() * 3,
          speed: 0.3 + Math.random() * 0.8,
          wobblePhase: Math.random() * Math.PI * 2,
          alpha: 0.3 + Math.random() * 0.5,
        });
      }

      vials.push(vial);
    }

    // Ambient particles (spores/motes)
    interface Mote {
      x: number;
      y: number;
      vx: number;
      vy: number;
      size: number;
      alpha: number;
      hue: number;
    }
    const motes: Mote[] = [];
    for (let i = 0; i < 60; i++) {
      motes.push({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.15,
        vy: -0.1 - Math.random() * 0.3,
        size: 0.5 + Math.random() * 1.5,
        alpha: 0.1 + Math.random() * 0.3,
        hue: 260 + Math.random() * 50,
      });
    }

    let time = 0;

    function drawVial(vial: Vial) {
      const baseY = h;
      const topY = h - vial.height;
      const neckStart = topY + vial.height * 0.15;
      const pulse = Math.sin(time * 2 + vial.pulsePhase) * 0.15 + 0.85;
      const glow = vial.glowIntensity * pulse;

      // Vial glass outline
      ctx!.beginPath();
      ctx!.moveTo(vial.x - vial.neckWidth, topY);
      ctx!.lineTo(vial.x - vial.neckWidth, neckStart);
      ctx!.quadraticCurveTo(vial.x - vial.baseWidth, neckStart + 20, vial.x - vial.baseWidth, neckStart + 40);
      ctx!.lineTo(vial.x - vial.baseWidth, baseY - vial.bulbRadius);
      ctx!.quadraticCurveTo(vial.x - vial.baseWidth, baseY, vial.x, baseY);
      ctx!.quadraticCurveTo(vial.x + vial.baseWidth, baseY, vial.x + vial.baseWidth, baseY - vial.bulbRadius);
      ctx!.lineTo(vial.x + vial.baseWidth, neckStart + 40);
      ctx!.quadraticCurveTo(vial.x + vial.baseWidth, neckStart + 20, vial.x + vial.neckWidth, neckStart);
      ctx!.lineTo(vial.x + vial.neckWidth, topY);
      ctx!.strokeStyle = `hsla(${vial.hue}, 30%, 60%, ${0.15 * glow})`;
      ctx!.lineWidth = 1.5;
      ctx!.stroke();

      // Liquid fill
      const liquidTop = baseY - (vial.height * 0.85 * vial.fillLevel);
      const liquidGrad = ctx!.createLinearGradient(vial.x, liquidTop, vial.x, baseY);
      liquidGrad.addColorStop(0, `hsla(${vial.hue}, ${vial.saturation}%, 65%, ${0.6 * glow})`);
      liquidGrad.addColorStop(0.4, `hsla(${vial.hue}, ${vial.saturation}%, 50%, ${0.5 * glow})`);
      liquidGrad.addColorStop(1, `hsla(${vial.hue + 10}, ${vial.saturation}%, 35%, ${0.7 * glow})`);

      ctx!.save();
      ctx!.beginPath();
      // Clip to vial shape
      ctx!.moveTo(vial.x - vial.neckWidth, topY);
      ctx!.lineTo(vial.x - vial.neckWidth, neckStart);
      ctx!.quadraticCurveTo(vial.x - vial.baseWidth, neckStart + 20, vial.x - vial.baseWidth, neckStart + 40);
      ctx!.lineTo(vial.x - vial.baseWidth, baseY - vial.bulbRadius);
      ctx!.quadraticCurveTo(vial.x - vial.baseWidth, baseY, vial.x, baseY);
      ctx!.quadraticCurveTo(vial.x + vial.baseWidth, baseY, vial.x + vial.baseWidth, baseY - vial.bulbRadius);
      ctx!.lineTo(vial.x + vial.baseWidth, neckStart + 40);
      ctx!.quadraticCurveTo(vial.x + vial.baseWidth, neckStart + 20, vial.x + vial.neckWidth, neckStart);
      ctx!.lineTo(vial.x + vial.neckWidth, topY);
      ctx!.closePath();
      ctx!.clip();

      // Draw liquid rectangle (with wave at top)
      ctx!.beginPath();
      const waveAmp = 2;
      ctx!.moveTo(vial.x - vial.baseWidth - 5, liquidTop);
      for (let wx = -vial.baseWidth - 5; wx <= vial.baseWidth + 5; wx += 2) {
        const wy = liquidTop + Math.sin((wx + time * 40) * 0.05) * waveAmp;
        ctx!.lineTo(vial.x + wx, wy);
      }
      ctx!.lineTo(vial.x + vial.baseWidth + 5, baseY + 5);
      ctx!.lineTo(vial.x - vial.baseWidth - 5, baseY + 5);
      ctx!.closePath();
      ctx!.fillStyle = liquidGrad;
      ctx!.fill();
      ctx!.restore();

      // Outer glow around vial
      const outerGlow = ctx!.createRadialGradient(
        vial.x, baseY - vial.height * 0.4, vial.baseWidth,
        vial.x, baseY - vial.height * 0.4, vial.baseWidth * 5
      );
      outerGlow.addColorStop(0, `hsla(${vial.hue}, ${vial.saturation}%, 60%, ${0.08 * glow})`);
      outerGlow.addColorStop(0.5, `hsla(${vial.hue}, ${vial.saturation}%, 50%, ${0.03 * glow})`);
      outerGlow.addColorStop(1, `hsla(${vial.hue}, 80%, 40%, 0)`);
      ctx!.fillStyle = outerGlow;
      ctx!.fillRect(vial.x - vial.baseWidth * 5, topY - 20, vial.baseWidth * 10, vial.height + 40);

      // Top meniscus glow
      if (vial.fillLevel > 0.1) {
        const meniscusGlow = ctx!.createRadialGradient(
          vial.x, liquidTop, 0,
          vial.x, liquidTop, vial.baseWidth * 2.5
        );
        meniscusGlow.addColorStop(0, `hsla(${vial.hue}, 100%, 80%, ${0.5 * glow})`);
        meniscusGlow.addColorStop(0.3, `hsla(${vial.hue}, 90%, 65%, ${0.2 * glow})`);
        meniscusGlow.addColorStop(1, `hsla(${vial.hue}, 80%, 50%, 0)`);
        ctx!.fillStyle = meniscusGlow;
        ctx!.beginPath();
        ctx!.arc(vial.x, liquidTop, vial.baseWidth * 2.5, 0, Math.PI * 2);
        ctx!.fill();
      }

      // Bubbles
      for (const bubble of vial.bubbles) {
        bubble.y -= bubble.speed;
        bubble.x += Math.sin(time * 3 + bubble.wobblePhase) * 0.3;

        if (bubble.y < liquidTop) {
          bubble.y = baseY - 10;
          bubble.x = vial.x + (Math.random() - 0.5) * vial.baseWidth * 0.6;
        }

        if (bubble.y > liquidTop) {
          ctx!.beginPath();
          ctx!.arc(bubble.x, bubble.y, bubble.radius, 0, Math.PI * 2);
          ctx!.fillStyle = `hsla(${vial.hue}, 100%, 85%, ${bubble.alpha * glow * 0.7})`;
          ctx!.fill();
          // Bubble highlight
          ctx!.beginPath();
          ctx!.arc(bubble.x - bubble.radius * 0.3, bubble.y - bubble.radius * 0.3, bubble.radius * 0.3, 0, Math.PI * 2);
          ctx!.fillStyle = `hsla(${vial.hue}, 100%, 95%, ${bubble.alpha * glow * 0.5})`;
          ctx!.fill();
        }
      }

      // Animate fill
      if (vial.fillLevel < vial.targetFill) {
        vial.fillLevel += vial.fillSpeed;
      }
    }

    function draw() {
      ctx!.clearRect(0, 0, w, h);
      time += 0.016;

      // Draw motes
      for (const mote of motes) {
        mote.x += mote.vx;
        mote.y += mote.vy;
        if (mote.y < -10) { mote.y = h + 10; mote.x = Math.random() * w; }
        if (mote.x < -10) mote.x = w + 10;
        if (mote.x > w + 10) mote.x = -10;

        const motePulse = Math.sin(time * 2 + mote.x * 0.01) * 0.3 + 0.7;
        ctx!.beginPath();
        ctx!.arc(mote.x, mote.y, mote.size, 0, Math.PI * 2);
        ctx!.fillStyle = `hsla(${mote.hue}, 80%, 75%, ${mote.alpha * motePulse})`;
        ctx!.fill();
      }

      // Draw vials
      for (const vial of vials) {
        drawVial(vial);
      }

      // Floor reflection
      const floorGrad = ctx!.createLinearGradient(0, h, 0, h - 80);
      floorGrad.addColorStop(0, `hsla(275, 60%, 40%, 0.12)`);
      floorGrad.addColorStop(1, `hsla(275, 60%, 30%, 0)`);
      ctx!.fillStyle = floorGrad;
      ctx!.fillRect(0, h - 80, w, 80);

      animationId = requestAnimationFrame(draw);
    }

    draw();

    window.addEventListener('resize', () => {
      w = canvas.width = window.innerWidth;
      h = canvas.height = window.innerHeight;
    });

    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(animationId);
    });
  }

  initLab();
  document.addEventListener('astro:after-swap', initLab);
</script>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;500;700&family=JetBrains+Mono:wght@400&display=swap');

  .hero-section {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    background: radial-gradient(ellipse at 50% 100%, #0d0018 0%, #020005 60%, #000 100%);
  }

  #lab-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-fog {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 30%;
    background: linear-gradient(to top, rgba(10, 0, 20, 0.6) 0%, transparent 100%);
    pointer-events: none;
    z-index: 1;
  }

  .hero-content {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    width: 100%;
    max-width: 900px;
    padding: 0 24px;
    color: #f0e8ff;
    z-index: 2;
  }

  .hero-reveal {
    opacity: 0;
    transform: translateY(30px);
    animation: heroReveal 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .hero-reveal-1 { animation-delay: 0.2s; }
  .hero-reveal-2 { animation-delay: 0.5s; }
  .hero-reveal-3 { animation-delay: 0.8s; }
  .hero-reveal-4 { animation-delay: 1.1s; }

  @keyframes heroReveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .service-tag {
    display: inline-block;
    padding: 6px 18px;
    background: rgba(168, 85, 247, 0.08);
    border: 1px solid rgba(168, 85, 247, 0.25);
    border-radius: 100px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #c084fc;
    margin-bottom: 1.5rem;
  }

  h1 {
    font-family: 'Outfit', sans-serif;
    font-size: clamp(2.4rem, 7vw, 4.2rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1.2rem;
    letter-spacing: -0.02em;
    background: linear-gradient(180deg, #ffffff 0%, #c8b8e8 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-family: 'Outfit', sans-serif;
    font-size: clamp(0.95rem, 2.5vw, 1.15rem);
    font-weight: 300;
    line-height: 1.7;
    color: rgba(200, 190, 220, 0.85);
    margin-bottom: 2.5rem;
    max-width: 680px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-wrapper {
    display: flex;
    gap: 1.2rem;
    justify-content: center;
  }

  .primary-cta,
  .secondary-cta {
    padding: 0.9rem 2.2rem;
    border-radius: 10px;
    font-family: 'Outfit', sans-serif;
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    letter-spacing: 0.01em;
  }

  .primary-cta {
    background: linear-gradient(135deg, #a855f7 0%, #7c3aed 100%);
    color: white;
    box-shadow: 0 4px 24px rgba(168, 85, 247, 0.3), inset 0 1px 0 rgba(255,255,255,0.1);
  }
  .primary-cta:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 8px 40px rgba(168, 85, 247, 0.5), inset 0 1px 0 rgba(255,255,255,0.15);
  }

  .secondary-cta {
    background: rgba(255, 255, 255, 0.04);
    color: #e0d4f5;
    border: 1px solid rgba(168, 85, 247, 0.2);
    backdrop-filter: blur(8px);
  }
  .secondary-cta:hover {
    background: rgba(168, 85, 247, 0.08);
    border-color: rgba(168, 85, 247, 0.4);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .cta-wrapper {
      flex-direction: column;
      gap: 0.8rem;
      align-items: center;
    }
    .primary-cta, .secondary-cta {
      width: 100%;
      max-width: 260px;
      text-align: center;
    }
    h1 {
      font-size: clamp(1.8rem, 7vw, 2.8rem);
    }
    .hero-subtitle br { display: none; }
  }
</style>
